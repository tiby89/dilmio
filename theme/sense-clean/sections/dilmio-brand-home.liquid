{{ 'dilmio-brand-home.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign trust_cards = section.blocks | where: "type", "trust_card"
  assign category_cards = section.blocks | where: "type", "category_card"
  assign featured_collection = section.settings.featured_collection
-%}

<div class="dilmio-brand-home">

  {% comment %} ===================== ZONE 1 — HERO ===================== {% endcomment %}
  <div class="dbh-hero">
    <div class="dbh-wrapper dbh-hero__grid{% if section.settings.hero_image == blank %} dbh-hero__grid--no-image{% endif %}">

      <div class="dbh-hero__content">
        {%- if section.settings.hero_heading != blank -%}
          <h1 class="dbh-hero__heading">{{ section.settings.hero_heading | escape }}</h1>
        {%- endif -%}
        {%- if section.settings.hero_subtext != blank -%}
          <p class="dbh-hero__subtext">{{ section.settings.hero_subtext | escape }}</p>
        {%- endif -%}
        {%- if section.settings.hero_cta_label != blank -%}
          <a
            href="{{ section.settings.hero_cta_link | default: '#' }}"
            class="dbh-btn dbh-btn--primary"
          >
            {{- section.settings.hero_cta_label | escape -}}
          </a>
        {%- endif -%}
      </div>

      {%- if section.settings.hero_image != blank -%}
        <div class="dbh-hero__image-wrap">
          {{
            section.settings.hero_image
            | image_url: width: 1200
            | image_tag:
              loading: 'eager',
              class: 'dbh-hero__image',
              widths: '400, 600, 800, 1000, 1200',
              sizes: '(min-width: 990px) 55vw, 100vw',
              alt: section.settings.hero_image.alt | escape
          }}
        </div>
      {%- endif -%}

    </div>
  </div>

  {% comment %} ===================== ZONE 2 — TRUST CARDS ===================== {% endcomment %}
  {%- if trust_cards.size > 0 -%}
    <div class="dbh-trust">
      <div class="dbh-wrapper">
        <div class="dbh-trust__grid">
          {%- for block in trust_cards -%}
            {%- if block.settings.title != blank -%}
              <div class="dbh-trust__item" {{ block.shopify_attributes }}>
                {%- if block.settings.icon != blank -%}
                  <span class="dbh-trust__icon" aria-hidden="true">{{ block.settings.icon }}</span>
                {%- endif -%}
                <div class="dbh-trust__text-wrap">
                  <span class="dbh-trust__title">{{ block.settings.title | escape }}</span>
                  {%- if block.settings.subtitle != blank -%}
                    <span class="dbh-trust__subtitle">{{ block.settings.subtitle | escape }}</span>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  {% comment %} ===================== ZONE 5 — BRAND CRITERIA ===================== {% endcomment %}
  {%- if section.settings.criteria_heading != blank
    or section.settings.criteria_1_title != blank
    or section.settings.criteria_2_title != blank
    or section.settings.criteria_3_title != blank
  -%}
    <div class="dbh-criteria">
      <div class="dbh-wrapper">
        {%- if section.settings.criteria_heading != blank -%}
          <h2 class="dbh-criteria__heading">{{ section.settings.criteria_heading | escape }}</h2>
        {%- endif -%}
        <div class="dbh-criteria__grid">
          {%- if section.settings.criteria_1_title != blank -%}
            <div class="dbh-criteria__item">
              <h3 class="dbh-criteria__title">{{ section.settings.criteria_1_title | escape }}</h3>
              {%- if section.settings.criteria_1_text != blank -%}
                <p class="dbh-criteria__text">{{ section.settings.criteria_1_text | escape }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}
          {%- if section.settings.criteria_2_title != blank -%}
            <div class="dbh-criteria__item">
              <h3 class="dbh-criteria__title">{{ section.settings.criteria_2_title | escape }}</h3>
              {%- if section.settings.criteria_2_text != blank -%}
                <p class="dbh-criteria__text">{{ section.settings.criteria_2_text | escape }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}
          {%- if section.settings.criteria_3_title != blank -%}
            <div class="dbh-criteria__item">
              <h3 class="dbh-criteria__title">{{ section.settings.criteria_3_title | escape }}</h3>
              {%- if section.settings.criteria_3_text != blank -%}
                <p class="dbh-criteria__text">{{ section.settings.criteria_3_text | escape }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  {% comment %} ===================== ZONE 3 — CATEGORY CARDS ===================== {% endcomment %}
  {%- if category_cards.size > 0 -%}
    <div class="dbh-categories">
      <div class="dbh-wrapper">
        {%- if section.settings.categories_heading != blank -%}
          <h2 class="dbh-section-heading">{{ section.settings.categories_heading | escape }}</h2>
        {%- endif -%}
        <div class="dbh-categories__grid">
          {%- for block in category_cards -%}
            {%- if block.settings.title != blank or block.settings.image != blank -%}
              <a
                {% if block.settings.link != blank %}
                  href="{{ block.settings.link }}"
                {% else %}
                  role="link" aria-disabled="true"
                {% endif %}
                class="dbh-category__card"
                {{ block.shopify_attributes }}
              >
                <div class="dbh-category__image-wrap">
                  {%- if block.settings.image != blank -%}
                    {{
                      block.settings.image
                      | image_url: width: 600
                      | image_tag:
                        loading: 'lazy',
                        class: 'dbh-category__img',
                        widths: '200, 300, 400, 600',
                        sizes: '(min-width: 990px) 25vw, 50vw',
                        alt: block.settings.title | escape
                    }}
                  {%- endif -%}
                </div>
                {%- if block.settings.badge_icon != blank -%}
                  <span class="dbh-category__badge" aria-hidden="true">{{ block.settings.badge_icon }}</span>
                {%- endif -%}
                <div class="dbh-category__body">
                  <div class="dbh-category__info">
                    {%- if block.settings.title != blank -%}
                      <p class="dbh-category__title">{{ block.settings.title | escape }}</p>
                    {%- endif -%}
                    {%- if block.settings.subtitle != blank -%}
                      <p class="dbh-category__subtitle">{{ block.settings.subtitle | escape }}</p>
                    {%- endif -%}
                  </div>
                  <span class="dbh-category__arrow" aria-hidden="true">&#8594;</span>
                </div>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  {% comment %} ===================== ZONE 4 — FEATURED PRODUCTS ===================== {% endcomment %}
  {%- if featured_collection != blank and featured_collection.all_products_count > 0 -%}
    <div class="dbh-products">
      <div class="dbh-wrapper">
        {%- if section.settings.featured_heading != blank -%}
          <h2 class="dbh-section-heading">{{ section.settings.featured_heading | escape }}</h2>
        {%- endif -%}
        <div class="dbh-products__grid">
          {%- for product in featured_collection.products limit: section.settings.featured_products_count -%}
            {%- render 'card-product',
              card_product: product,
              media_aspect_ratio: 'square',
              show_secondary_image: false,
              show_vendor: false,
              show_rating: false,
              lazy_load: true,
              skip_styles: forloop.index > 1,
              quick_add: false,
              section_id: section.id
            -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  {% comment %} ===================== ZONE 6 — BOTTOM BANNER ===================== {% endcomment %}
  {%- if section.settings.banner_heading != blank -%}
    <div
      class="dbh-banner{% if section.settings.banner_image != blank %} dbh-banner--has-image{% endif %}"
      {%- if section.settings.banner_image != blank -%}
        style="background-image: url('{{ section.settings.banner_image | image_url: width: 2000 }}')"
      {%- endif -%}
    >
      <div class="dbh-banner__overlay"></div>
      <div class="dbh-wrapper dbh-banner__content">
        <h2 class="dbh-banner__heading">{{ section.settings.banner_heading | escape }}</h2>
        {%- if section.settings.banner_cta_label != blank -%}
          <a
            href="{{ section.settings.banner_cta_link | default: '#' }}"
            class="dbh-btn dbh-btn--outline"
          >
            {{- section.settings.banner_cta_label | escape -}}
          </a>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

</div>

{% schema %}
{
  "name": "DILMIO Brand Home",
  "tag": "section",
  "class": "dilmio-brand-home-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "text",
      "id": "hero_heading",
      "label": "Heading",
      "default": "Productos útiles para una casa más práctica."
    },
    {
      "type": "textarea",
      "id": "hero_subtext",
      "label": "Subtext",
      "default": "Seleccionamos artículos para el hogar, la cocina y el orden que destacan por su utilidad, simplicidad y buena relación calidad/precio."
    },
    {
      "type": "text",
      "id": "hero_cta_label",
      "label": "CTA label",
      "default": "Ver catálogo"
    },
    {
      "type": "url",
      "id": "hero_cta_link",
      "label": "CTA link"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "header",
      "content": "Categorías"
    },
    {
      "type": "text",
      "id": "categories_heading",
      "label": "Section heading",
      "default": "Explorar categorías"
    },
    {
      "type": "header",
      "content": "Productos destacados"
    },
    {
      "type": "text",
      "id": "featured_heading",
      "label": "Section heading",
      "default": "Productos destacados"
    },
    {
      "type": "collection",
      "id": "featured_collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "featured_products_count",
      "min": 2,
      "max": 8,
      "step": 2,
      "default": 4,
      "label": "Products to show"
    },
    {
      "type": "header",
      "content": "Criterios de marca"
    },
    {
      "type": "text",
      "id": "criteria_heading",
      "label": "Section heading",
      "default": "No vendemos de todo. Elegimos con criterio."
    },
    {
      "type": "text",
      "id": "criteria_1_title",
      "label": "Criteria 1 title",
      "default": "Útil de verdad"
    },
    {
      "type": "text",
      "id": "criteria_1_text",
      "label": "Criteria 1 text",
      "default": "Solo añadimos productos que resuelven algo real."
    },
    {
      "type": "text",
      "id": "criteria_2_title",
      "label": "Criteria 2 title",
      "default": "Fácil de entender"
    },
    {
      "type": "text",
      "id": "criteria_2_text",
      "label": "Criteria 2 text",
      "default": "Sin tecnicismos. Sabes exactamente qué compras y para qué."
    },
    {
      "type": "text",
      "id": "criteria_3_title",
      "label": "Criteria 3 title",
      "default": "Compra clara"
    },
    {
      "type": "text",
      "id": "criteria_3_text",
      "label": "Criteria 3 text",
      "default": "Precio justo, envío con seguimiento, devolución sin complicaciones."
    },
    {
      "type": "header",
      "content": "Banner inferior"
    },
    {
      "type": "text",
      "id": "banner_heading",
      "label": "Heading",
      "default": "Mejora tu casa hoy. Pequeños cambios, gran diferencia."
    },
    {
      "type": "text",
      "id": "banner_cta_label",
      "label": "CTA label",
      "default": "Ver novedades de la semana"
    },
    {
      "type": "url",
      "id": "banner_cta_link",
      "label": "CTA link"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Background image (optional)"
    }
  ],
  "blocks": [
    {
      "type": "trust_card",
      "name": "Trust card",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon or emoji",
          "default": "✓"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Punto de confianza"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle (optional)"
        }
      ]
    },
    {
      "type": "category_card",
      "name": "Category card",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "badge_icon",
          "label": "Badge icon or emoji",
          "default": "🍳"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Categoría"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle (e.g. Desde 9,99€)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DILMIO Brand Home",
      "blocks": [
        {
          "type": "trust_card",
          "settings": {
            "icon": "🔒",
            "title": "Pago 100% seguro",
            "subtitle": "Tarjeta, Bizum, PayPal"
          }
        },
        {
          "type": "trust_card",
          "settings": {
            "icon": "🚚",
            "title": "Seguimiento del pedido",
            "subtitle": "Envío con número de seguimiento"
          }
        },
        {
          "type": "trust_card",
          "settings": {
            "icon": "↩",
            "title": "Devoluciones fáciles",
            "subtitle": "30 días sin preguntas"
          }
        },
        {
          "type": "trust_card",
          "settings": {
            "icon": "✉",
            "title": "Atención al cliente",
            "subtitle": "hola@dilmio.com"
          }
        },
        {
          "type": "category_card",
          "settings": {
            "badge_icon": "🍳",
            "title": "Cocina práctica",
            "subtitle": "Ver productos"
          }
        },
        {
          "type": "category_card",
          "settings": {
            "badge_icon": "📦",
            "title": "Orden y organización",
            "subtitle": "Ver productos"
          }
        },
        {
          "type": "category_card",
          "settings": {
            "badge_icon": "🏠",
            "title": "Hogar útil",
            "subtitle": "Ver productos"
          }
        },
        {
          "type": "category_card",
          "settings": {
            "badge_icon": "✨",
            "title": "Novedades seleccionadas",
            "subtitle": "Ver novedades"
          }
        }
      ]
    }
  ]
}
{% endschema %}
