{{ 'dilmio-brand-home.css' | asset_url | stylesheet_tag }}
{{ 'dilmio-card-rating.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign category_cards = section.blocks | where: "type", "category_card"
  assign featured_collection = section.settings.featured_collection
-%}

<div class="dilmio-brand-home">

  {% comment %} ===================== ZONE 1 — AMBIENT BOXED HERO ===================== {% endcomment %}
  <div class="dbh-hero{% if section.settings.hero_image != blank %} dbh-hero--has-image{% endif %}">

    {%- if section.settings.hero_image != blank -%}
      {%- comment -%} Card: imagen + texto superpuesto, rodeada por gradiente ambiental {%- endcomment -%}
      <div class="dbh-hero__card">
        {{
          section.settings.hero_image
          | image_url: width: 2000
          | image_tag:
            loading: 'eager',
            class: 'dbh-hero__card-img',
            widths: '400, 600, 800, 1000, 1200, 1600, 2000',
            sizes: '100vw',
            alt: section.settings.hero_image.alt | escape
        }}
        <div class="dbh-hero__content">
          {%- if section.settings.hero_heading != blank -%}
            <h1 class="dbh-hero__heading">{{ section.settings.hero_heading | escape }}</h1>
          {%- endif -%}
          {%- if section.settings.hero_subtext != blank -%}
            <p class="dbh-hero__subtext">{{ section.settings.hero_subtext | escape }}</p>
          {%- endif -%}
          {%- if section.settings.hero_cta_label != blank -%}
            <a
              href="{{ section.settings.hero_cta_link | default: '#' }}"
              class="dbh-btn dbh-btn--primary"
            >
              {{- section.settings.hero_cta_label | escape -}}
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- else -%}
      {%- comment -%} Fallback sin imagen: texto centrado sobre fondo crema {%- endcomment -%}
      <div class="dbh-wrapper dbh-hero__content">
        {%- if section.settings.hero_heading != blank -%}
          <h1 class="dbh-hero__heading">{{ section.settings.hero_heading | escape }}</h1>
        {%- endif -%}
        {%- if section.settings.hero_subtext != blank -%}
          <p class="dbh-hero__subtext">{{ section.settings.hero_subtext | escape }}</p>
        {%- endif -%}
        {%- if section.settings.hero_cta_label != blank -%}
          <a
            href="{{ section.settings.hero_cta_link | default: '#' }}"
            class="dbh-btn dbh-btn--primary"
          >
            {{- section.settings.hero_cta_label | escape -}}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>

  {% comment %} ===================== ZONE 3 — CATEGORY CARDS ===================== {% endcomment %}
  {%- if category_cards.size > 0 -%}
    <div class="dbh-categories">
      {%- if section.settings.categories_heading != blank -%}
        <div class="dbh-wrapper">
          <h2 class="dbh-section-heading">{{ section.settings.categories_heading | escape }}</h2>
        </div>
      {%- endif -%}
      <div class="dbh-categories__grid-wrap">
        <div class="dbh-categories__grid">
          {%- for block in category_cards -%}
            {%- if block.settings.title != blank or block.settings.image != blank -%}
              <a
                {% if block.settings.link != blank %}
                  href="{{ block.settings.link }}"
                {% else %}
                  role="link" aria-disabled="true"
                {% endif %}
                class="dbh-category__card"
                {{ block.shopify_attributes }}
              >
                <div class="dbh-category__image-wrap">
                  {%- if block.settings.image != blank -%}
                    {{
                      block.settings.image
                      | image_url: width: 600
                      | image_tag:
                        loading: 'lazy',
                        class: 'dbh-category__img',
                        widths: '200, 300, 400, 600',
                        sizes: '(min-width: 990px) 25vw, 75vw',
                        alt: block.settings.title | escape
                    }}
                  {%- endif -%}
                </div>
                <div class="dbh-category__body">
                  <div class="dbh-category__info">
                    {%- if block.settings.title != blank -%}
                      <p class="dbh-category__title">{{ block.settings.title | escape }}</p>
                    {%- endif -%}
                    {%- if block.settings.subtitle != blank -%}
                      <p class="dbh-category__subtitle">{{ block.settings.subtitle | escape }}</p>
                    {%- endif -%}
                  </div>
                </div>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  {% comment %} ===================== ZONE 4 — FEATURED PRODUCTS ===================== {% endcomment %}
  {%- if featured_collection != blank and featured_collection.all_products_count > 0 -%}
    <div class="dbh-products">
      <div class="dbh-wrapper">
        <div class="dbh-products__header">
          <div class="dbh-products__header-left">
            {%- if section.settings.featured_heading != blank -%}
              <h2 class="dbh-section-heading dbh-products__heading">{{ section.settings.featured_heading | escape }}</h2>
            {%- endif -%}
            {%- if section.settings.featured_subtitle != blank -%}
              <p class="dbh-products__subtitle">{{ section.settings.featured_subtitle | escape }}</p>
            {%- endif -%}
          </div>
          {%- if section.settings.featured_view_all_label != blank -%}
            <a href="{{ featured_collection.url }}" class="dbh-products__view-all">
              {{- section.settings.featured_view_all_label | replace: '→', '' | strip | escape -}}
            </a>
          {%- endif -%}
        </div>
      </div>
      <div class="dbh-products__carousel-wrap">
        <div class="dbh-products__carousel" id="dbh-carousel-{{ section.id }}">
          {%- for product in featured_collection.products limit: section.settings.featured_products_count -%}
            {%- assign badge_text = nil -%}
            {%- for tag in product.tags -%}
              {%- if tag contains 'badge:' -%}
                {%- assign badge_text = tag | remove: 'badge:' | strip -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
            <a href="{{ product.url }}" class="dbh-pcard">
              <div class="dbh-pcard__image-wrap">
                {%- if badge_text != blank -%}
                  <span class="dbh-pcard__badge">{{ badge_text | escape }}</span>
                {%- endif -%}
                {%- if product.featured_image != blank -%}
                  {{
                    product.featured_image
                    | image_url: width: 600
                    | image_tag:
                      loading: 'lazy',
                      class: 'dbh-pcard__img',
                      widths: '200, 300, 400, 600',
                      sizes: '(min-width: 990px) 25vw, 72vw',
                      alt: product.featured_image.alt | default: product.title | escape
                  }}
                {%- else -%}
                  <div class="dbh-pcard__img-placeholder"></div>
                {%- endif -%}
              </div>
              <div class="dbh-pcard__body">
                <p class="dbh-pcard__name">{{ product.title | escape }}</p>
                {%- render 'dilmio-card-rating', product: product -%}
                <div class="dbh-pcard__price">
                  {%- if product.compare_at_price > product.price -%}
                    <s class="dbh-pcard__price-was">{{ product.compare_at_price | money }}</s>
                  {%- endif -%}
                  <span class="dbh-pcard__price-now">{{ product.price | money }}</span>
                </div>
              </div>
            </a>
          {%- endfor -%}
        </div>
      </div>
      {%- if section.settings.featured_view_all_label != blank -%}
        <a href="{{ featured_collection.url }}" class="dbh-products__view-all-mobile">
          {{- section.settings.featured_view_all_label | replace: '→', '' | strip | escape -}}
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}

  {% comment %} ===================== ZONE 4.5 — BRAND STORY ===================== {% endcomment %}
  <div class="dbh-brandstory">
    <div class="dbh-wrapper">
      <div class="dbh-brandstory__card">
        <div class="dbh-brandstory__content">
          {%- if section.settings.brandstory_heading != blank -%}
            <h2 class="dbh-brandstory__heading">{{ section.settings.brandstory_heading | escape }}</h2>
          {%- endif -%}
          {%- if section.settings.brandstory_text != blank -%}
            <p class="dbh-brandstory__body">{{ section.settings.brandstory_text | escape }}</p>
          {%- endif -%}
          {%- if section.settings.brandstory_point_1 != blank
            or section.settings.brandstory_point_2 != blank
            or section.settings.brandstory_point_3 != blank
            or section.settings.brandstory_point_4 != blank
          -%}
            <div class="dbh-brandstory__tags">
              {%- if section.settings.brandstory_point_1 != blank -%}
                <span class="dbh-brandstory__tag">{{ section.settings.brandstory_point_1 | escape }}</span>
              {%- endif -%}
              {%- if section.settings.brandstory_point_2 != blank -%}
                <span class="dbh-brandstory__tag">{{ section.settings.brandstory_point_2 | escape }}</span>
              {%- endif -%}
              {%- if section.settings.brandstory_point_3 != blank -%}
                <span class="dbh-brandstory__tag">{{ section.settings.brandstory_point_3 | escape }}</span>
              {%- endif -%}
              {%- if section.settings.brandstory_point_4 != blank -%}
                <span class="dbh-brandstory__tag">{{ section.settings.brandstory_point_4 | escape }}</span>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
        <div class="dbh-brandstory__visual">
          {%- if section.settings.brandstory_image != blank -%}
            {{
              section.settings.brandstory_image
              | image_url: width: 800
              | image_tag:
                loading: 'lazy',
                class: 'dbh-brandstory__img',
                widths: '400, 600, 800',
                sizes: '(min-width: 990px) 40vw, 100vw',
                alt: ''
            }}
          {%- else -%}
            <div class="dbh-brandstory__img-placeholder"></div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>

  {% comment %} ===================== ZONE 6 — BOTTOM BANNER (GOD 11.3b) ===================== {% endcomment %}
  {%- if section.settings.banner_heading != blank -%}
    <div class="dbh-banner__reveal">
      <div class="dbh-banner{% if section.settings.banner_image != blank %} dbh-banner--has-image{% endif %}">
        <div class="dbh-banner__sticky">
          <div class="dbh-banner__frame">
            {%- if section.settings.banner_image != blank -%}
              <div class="dbh-banner__bg">
                {{
                  section.settings.banner_image
                  | image_url: width: 2000
                  | image_tag:
                    loading: 'lazy',
                    class: 'dbh-banner__bg-img',
                    widths: '750, 1000, 1400, 1800, 2000',
                    sizes: '100vw',
                    alt: ''
                }}
              </div>
            {%- endif -%}
            <div class="dbh-banner__overlay"></div>
            <div class="dbh-banner__content">
              {%- if section.settings.banner_label != blank -%}
                <p class="dbh-banner__label">{{ section.settings.banner_label | escape }}</p>
              {%- endif -%}
              <h2 class="dbh-banner__heading">{{ section.settings.banner_heading | escape }}</h2>
              {%- if section.settings.banner_cta_label != blank and section.settings.banner_cta_link != blank -%}
                <a
                  href="{{ section.settings.banner_cta_link }}"
                  class="dbh-btn dbh-btn--outline dbh-banner__cta"
                >
                  {{- section.settings.banner_cta_label | escape -}}
                </a>
              {%- endif -%}
            </div>
          </div>
        </div>
      </div>
    </div>
  {%- endif -%}


  {% comment %} ===================== ZONE 7 — FAQ + WHATSAPP ===================== {% endcomment %}
  <div class="dbh-faq">
    <div class="dbh-wrapper">
      <div class="dbh-faq__card">
        <div class="dbh-faq__left">
          <h2 class="dbh-faq__heading">¿Tienes alguna duda antes de comprar?</h2>
          <p class="dbh-faq__body">Consulta las preguntas más habituales o escríbenos. Queremos que compres con claridad.</p>
          <a
            href="{{ section.settings.whatsapp_url | default: '#' }}"
            class="dbh-btn dbh-btn--whatsapp"
            {%- if section.settings.whatsapp_url != blank -%}
              target="_blank" rel="noopener noreferrer"
            {%- endif -%}
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Hablar por WhatsApp
          </a>
        </div>
        <div class="dbh-faq__right">
          <div class="dbh-faq__list">
            <details class="dbh-faq__item">
              <summary class="dbh-faq__question">¿Mi pedido tiene seguimiento?</summary>
              <p class="dbh-faq__answer">Sí. Cuando el pedido se prepara, recibirás la información de seguimiento disponible.</p>
            </details>
            <details class="dbh-faq__item">
              <summary class="dbh-faq__question">¿Cuánto tarda el envío?</summary>
              <p class="dbh-faq__answer">El plazo puede variar según el producto y el destino. Siempre mostraremos la información más clara posible durante la compra.</p>
            </details>
            <details class="dbh-faq__item">
              <summary class="dbh-faq__question">¿Puedo devolver mi pedido?</summary>
              <p class="dbh-faq__answer">Sí. Puedes revisar las condiciones de devolución antes de comprar y contactar con nosotros si tienes dudas.</p>
            </details>
            <details class="dbh-faq__item">
              <summary class="dbh-faq__question">¿Cómo sé si un producto es para mí?</summary>
              <p class="dbh-faq__answer">Intentamos explicar cada producto de forma simple, con beneficios claros y detalles útiles para ayudarte a decidir.</p>
            </details>
          </div>
        </div>
      </div>
    </div>
  </div>

</div>

{% schema %}
{
  "name": "DILMIO Brand Home",
  "tag": "section",
  "class": "dilmio-brand-home-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "text",
      "id": "hero_heading",
      "label": "Heading",
      "default": "Productos útiles para una casa más práctica."
    },
    {
      "type": "textarea",
      "id": "hero_subtext",
      "label": "Subtext",
      "default": "Seleccionamos artículos para el hogar, la cocina y el orden que destacan por su utilidad, simplicidad y buena relación calidad/precio."
    },
    {
      "type": "text",
      "id": "hero_cta_label",
      "label": "CTA label",
      "default": "Ver catálogo"
    },
    {
      "type": "url",
      "id": "hero_cta_link",
      "label": "CTA link"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "header",
      "content": "Categorías"
    },
    {
      "type": "text",
      "id": "categories_heading",
      "label": "Section heading",
      "default": "Explorar categorías"
    },
    {
      "type": "header",
      "content": "Productos destacados"
    },
    {
      "type": "text",
      "id": "featured_heading",
      "label": "Section heading",
      "default": "Selección destacada"
    },
    {
      "type": "text",
      "id": "featured_subtitle",
      "label": "Subtitle"
    },
    {
      "type": "text",
      "id": "featured_view_all_label",
      "label": "View all link label",
      "default": "Ver catálogo completo →"
    },
    {
      "type": "collection",
      "id": "featured_collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "featured_products_count",
      "min": 2,
      "max": 8,
      "step": 2,
      "default": 4,
      "label": "Products to show"
    },
    {
      "type": "header",
      "content": "Criterios de marca"
    },
    {
      "type": "text",
      "id": "criteria_heading",
      "label": "Section heading",
      "default": "No vendemos de todo. Elegimos con criterio."
    },
    {
      "type": "text",
      "id": "criteria_1_title",
      "label": "Criteria 1 title",
      "default": "Útil de verdad"
    },
    {
      "type": "text",
      "id": "criteria_1_text",
      "label": "Criteria 1 text",
      "default": "Solo añadimos productos que resuelven algo real."
    },
    {
      "type": "text",
      "id": "criteria_2_title",
      "label": "Criteria 2 title",
      "default": "Fácil de entender"
    },
    {
      "type": "text",
      "id": "criteria_2_text",
      "label": "Criteria 2 text",
      "default": "Sin tecnicismos. Sabes exactamente qué compras y para qué."
    },
    {
      "type": "text",
      "id": "criteria_3_title",
      "label": "Criteria 3 title",
      "default": "Compra clara"
    },
    {
      "type": "text",
      "id": "criteria_3_text",
      "label": "Criteria 3 text",
      "default": "Precio justo, envío con seguimiento, devolución sin complicaciones."
    },
    {
      "type": "header",
      "content": "Banner inferior"
    },
    {
      "type": "text",
      "id": "banner_heading",
      "label": "Heading",
      "default": "Mejora tu casa hoy. Pequeños cambios, gran diferencia."
    },
    {
      "type": "text",
      "id": "banner_cta_label",
      "label": "CTA label",
      "default": "Ver novedades de la semana"
    },
    {
      "type": "url",
      "id": "banner_cta_link",
      "label": "CTA link"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Background image (optional)"
    },
    {
      "type": "text",
      "id": "banner_label",
      "label": "Eyebrow label (optional)",
      "info": "Short label above the heading — e.g. 'DILMIO — Colección 2025'"
    },
    {
      "type": "header",
      "content": "Marca — Historia"
    },
    {
      "type": "text",
      "id": "brandstory_heading",
      "label": "Titular",
      "default": "Elegimos productos útiles para casas reales."
    },
    {
      "type": "textarea",
      "id": "brandstory_text",
      "label": "Texto",
      "default": "En Dilmio buscamos soluciones prácticas, fáciles de usar y con sentido para el día a día. Filtramos cada producto para que compres con claridad, sin perder tiempo y sin sensación de riesgo."
    },
    {
      "type": "text",
      "id": "brandstory_point_1",
      "label": "Punto 1",
      "default": "Selección práctica"
    },
    {
      "type": "text",
      "id": "brandstory_point_2",
      "label": "Punto 2",
      "default": "Compra segura"
    },
    {
      "type": "text",
      "id": "brandstory_point_3",
      "label": "Punto 3",
      "default": "Envío con seguimiento"
    },
    {
      "type": "text",
      "id": "brandstory_point_4",
      "label": "Punto 4",
      "default": "Atención cercana"
    },
    {
      "type": "image_picker",
      "id": "brandstory_image",
      "label": "Imagen de marca (opcional)"
    },
    {
      "type": "header",
      "content": "FAQ + Soporte"
    },
    {
      "type": "url",
      "id": "whatsapp_url",
      "label": "Enlace WhatsApp"
    },
  ],
  "blocks": [
    {
      "type": "trust_card",
      "name": "Trust card",
      "limit": 4,
      "settings": [
        {
          "type": "select",
          "id": "icon_svg",
          "label": "SVG icon",
          "options": [
            { "value": "", "label": "Ninguno" },
            { "value": "icon-lock", "label": "Candado (pago seguro)" },
            { "value": "icon-truck", "label": "Camión (envío)" },
            { "value": "icon-return", "label": "Flecha circular (devoluciones)" },
            { "value": "icon-chat-bubble", "label": "Burbuja (atención)" },
            { "value": "icon-box", "label": "Caja (paquete)" },
            { "value": "icon-padlock", "label": "Candado alt" },
            { "value": "dilmio-icon-shield", "label": "Escudo (pago seguro)" },
            { "value": "dilmio-icon-box", "label": "Caja (seguimiento)" },
            { "value": "dilmio-icon-return", "label": "Flechas (devoluciones)" },
            { "value": "dilmio-icon-headset", "label": "Auricular (atención)" }
          ],
          "default": ""
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Emoji (fallback si no hay SVG)",
          "default": "✓"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Punto de confianza"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle (optional)"
        }
      ]
    },
    {
      "type": "category_card",
      "name": "Category card",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "badge_icon",
          "label": "Badge icon or emoji",
          "default": "🍳"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Categoría"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle (e.g. Desde 9,99€)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
