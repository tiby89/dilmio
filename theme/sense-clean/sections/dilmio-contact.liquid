{{ 'dilmio-contact.css' | asset_url | stylesheet_tag }}

<div class="dilmio-contact">

  {%- comment -%} ── Hero editorial ──────────────────────────── {%- endcomment -%}
  <div class="dilmio-contact__hero">
    <span class="dilmio-contact__eyebrow">{{ section.settings.hero_eyebrow }}</span>
    <h1 class="dilmio-contact__title">{{ section.settings.hero_title }}</h1>
    <p class="dilmio-contact__subcopy">
      {{ section.settings.hero_subcopy }}
    </p>
    {%- if settings.dilmio_whatsapp_url != blank -%}
      <a href="{{ settings.dilmio_whatsapp_url }}" class="dilmio-contact__whatsapp" target="_blank" rel="noopener">
        <span class="dilmio-contact__whatsapp-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="18" height="18"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        </span>
        {{ section.settings.whatsapp_label }}
      </a>
    {%- endif -%}
  </div>

  {%- comment -%} ── Grid: formulario + card soporte ─────────── {%- endcomment -%}
  <div class="dilmio-contact__body">

    {%- comment -%} Formulario card ─────────────────────────── {%- endcomment -%}
    <div class="dilmio-contact__form-card">
      <h2 class="dilmio-contact__form-title">{{ section.settings.form_title }}</h2>

      {%- liquid
        assign contact_form_class = 'dilmio-contact__form'
        if settings.animations_reveal_on_scroll
          assign contact_form_class = 'dilmio-contact__form scroll-trigger animate--fade-in'
        endif
      -%}

      {%- form 'contact', id: 'DilmioContactForm', class: contact_form_class -%}

        {%- if form.posted_successfully? -%}
          <div class="form-status" tabindex="-1" autofocus>
            <span aria-hidden="true">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            {{ section.settings.form_success_msg }}
          </div>
        {%- elsif form.errors -%}
          <div class="form__message" role="alert">
            <p class="contact__field-error">
              {{ section.settings.form_error_msg }}
            </p>
          </div>
        {%- endif -%}

        <div class="contact__fields">
          <div class="field">
            <input
              class="field__input"
              autocomplete="name"
              type="text"
              id="DilmioContactForm-name"
              name="contact[Nombre]"
              value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
              placeholder="{{ section.settings.form_field_name }}"
            >
            <label class="field__label" for="DilmioContactForm-name">{{ section.settings.form_field_name }}</label>
          </div>

          <div class="field field--with-error">
            <input
              autocomplete="email"
              type="email"
              id="DilmioContactForm-email"
              class="field__input"
              name="contact[email]"
              spellcheck="false"
              autocapitalize="off"
              value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
              aria-required="true"
              {% if form.errors contains 'email' %}
                aria-invalid="true"
                aria-describedby="DilmioContactForm-email-error"
              {% endif %}
              placeholder="{{ section.settings.form_field_email }} *"
            >
            <label class="field__label" for="DilmioContactForm-email">
              {{ section.settings.form_field_email }} <span aria-hidden="true">*</span>
            </label>
            {%- if form.errors contains 'email' -%}
              <small class="contact__field-error" id="DilmioContactForm-email-error">
                {{ form.errors.translated_fields.email | capitalize }}
                {{ form.errors.messages.email }}
              </small>
            {%- endif -%}
          </div>
        </div>

        <div class="field">
          <input
            type="tel"
            id="DilmioContactForm-phone"
            class="field__input"
            autocomplete="tel"
            name="contact[Teléfono]"
            pattern="[0-9\-]*"
            value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
            placeholder="{{ section.settings.form_field_phone }}"
          >
          <label class="field__label" for="DilmioContactForm-phone">{{ section.settings.form_field_phone }}</label>
        </div>

        <div class="field field--textarea">
          <textarea
            rows="6"
            id="DilmioContactForm-body"
            class="text-area field__input"
            name="contact[Mensaje]"
            placeholder="{{ section.settings.form_field_message }}"
          >{{- form.body -}}</textarea>
          <label class="form__label field__label" for="DilmioContactForm-body">
            {{ section.settings.form_field_message }}
          </label>
        </div>

        <button type="submit" class="dilmio-contact__submit">
          {{ section.settings.form_submit_label }}
        </button>

      {%- endform -%}
    </div>

    {%- comment -%} Card de soporte ─────────────────────────── {%- endcomment -%}
    <div class="dilmio-contact__support-card">
      <div class="dilmio-contact__support-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="20" height="20"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2s-2 .9-2 2H8c0-2.21 1.79-4 4-4s4 1.79 4 4c0 .88-.36 1.68-.93 2.25z"/></svg>
      </div>
      <h2 class="dilmio-contact__support-title">{{ section.settings.support_title }}</h2>
      <p class="dilmio-contact__support-text">
        {{ section.settings.support_text }}
      </p>
      <ul class="dilmio-contact__support-list">
        <li class="dilmio-contact__support-item">
          <span class="dilmio-contact__support-check" aria-hidden="true">
            <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          {{ section.settings.support_bullet_1 }}
        </li>
        <li class="dilmio-contact__support-item">
          <span class="dilmio-contact__support-check" aria-hidden="true">
            <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          {{ section.settings.support_bullet_2 }}
        </li>
        <li class="dilmio-contact__support-item">
          <span class="dilmio-contact__support-check" aria-hidden="true">
            <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          {{ section.settings.support_bullet_3 }}
        </li>
        <li class="dilmio-contact__support-item">
          <span class="dilmio-contact__support-check" aria-hidden="true">
            <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          {{ section.settings.support_bullet_4 }}
        </li>
      </ul>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "DILMIO Contact",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "text",
      "id": "hero_eyebrow",
      "label": "Eyebrow",
      "default": "Atención DILMIO"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Título",
      "default": "¿Necesitas ayuda?"
    },
    {
      "type": "textarea",
      "id": "hero_subcopy",
      "label": "Subtítulo",
      "default": "Escríbenos y te responderemos el mismo día. También puedes contactarnos por WhatsApp si necesitas ayuda rápida con tu pedido o producto."
    },
    {
      "type": "header",
      "content": "WhatsApp"
    },
    {
      "type": "text",
      "id": "whatsapp_label",
      "label": "Texto del botón",
      "default": "Hablar por WhatsApp"
    },
    {
      "type": "header",
      "content": "Formulario"
    },
    {
      "type": "text",
      "id": "form_title",
      "label": "Título del formulario",
      "default": "Envíanos un mensaje"
    },
    {
      "type": "text",
      "id": "form_field_name",
      "label": "Campo: Nombre",
      "default": "Nombre"
    },
    {
      "type": "text",
      "id": "form_field_email",
      "label": "Campo: Correo electrónico",
      "default": "Correo electrónico"
    },
    {
      "type": "text",
      "id": "form_field_phone",
      "label": "Campo: Teléfono",
      "default": "Teléfono (opcional)"
    },
    {
      "type": "text",
      "id": "form_field_message",
      "label": "Campo: Mensaje",
      "default": "¿En qué podemos ayudarte?"
    },
    {
      "type": "text",
      "id": "form_submit_label",
      "label": "Botón: Enviar",
      "default": "Enviar mensaje"
    },
    {
      "type": "text",
      "id": "form_success_msg",
      "label": "Mensaje de éxito",
      "default": "Mensaje enviado. Te responderemos pronto."
    },
    {
      "type": "text",
      "id": "form_error_msg",
      "label": "Mensaje de error",
      "default": "Revisa los campos marcados e inténtalo de nuevo."
    },
    {
      "type": "header",
      "content": "Card de ayuda"
    },
    {
      "type": "text",
      "id": "support_title",
      "label": "Título",
      "default": "Respuesta el mismo día"
    },
    {
      "type": "textarea",
      "id": "support_text",
      "label": "Descripción",
      "default": "Revisamos cada consulta de forma personal para ayudarte antes y después de comprar."
    },
    {
      "type": "text",
      "id": "support_bullet_1",
      "label": "Bullet 1",
      "default": "Respuesta en el día"
    },
    {
      "type": "text",
      "id": "support_bullet_2",
      "label": "Bullet 2",
      "default": "Ayuda con pedidos"
    },
    {
      "type": "text",
      "id": "support_bullet_3",
      "label": "Bullet 3",
      "default": "Dudas antes de comprar"
    },
    {
      "type": "text",
      "id": "support_bullet_4",
      "label": "Bullet 4",
      "default": "Cambios y devoluciones"
    }
  ],
  "presets": [
    {
      "name": "DILMIO Contact"
    }
  ]
}
{% endschema %}
