{{ 'dilmio-product.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign landing_product = nil
  if request.page_type == 'product'
    assign landing_product = product
  elsif section.settings.product != blank
    assign landing_product = section.settings.product
  endif
-%}

{%- liquid
  assign hero_headline        = landing_product.metafields.custom.dilmio_hero_headline.value
  assign hero_subheadline     = landing_product.metafields.custom.dilmio_hero_subheadline.value
  assign demo_video_url       = landing_product.metafields.custom.dilmio_demo_video_url.value
  assign benefit_1            = landing_product.metafields.custom.dilmio_benefit_1.value
  assign benefit_2            = landing_product.metafields.custom.dilmio_benefit_2.value
  assign benefit_3            = landing_product.metafields.custom.dilmio_benefit_3.value
  assign benefit_4            = landing_product.metafields.custom.dilmio_benefit_4.value
  assign faq_question_1       = landing_product.metafields.custom.dilmio_faq_question_1.value
  assign faq_answer_1         = landing_product.metafields.custom.dilmio_faq_answer_1.value
  assign faq_question_2       = landing_product.metafields.custom.dilmio_faq_question_2.value
  unless faq_question_2
    assign faq_question_2     = landing_product.metafields.custom.custom_dilmio_faq_question_2.value
  endunless
  assign faq_answer_2         = landing_product.metafields.custom.dilmio_faq_answer_2.value
  unless faq_answer_2
    assign faq_answer_2       = landing_product.metafields.custom.custom_dilmio_faq_answer_2.value
  endunless
  assign faq_question_3       = landing_product.metafields.custom.dilmio_faq_question_3.value
  unless faq_question_3
    assign faq_question_3     = landing_product.metafields.custom.custom_dilmio_faq_question_3.value
  endunless
  assign faq_answer_3         = landing_product.metafields.custom.dilmio_faq_answer_3.value
  unless faq_answer_3
    assign faq_answer_3       = landing_product.metafields.custom.custom_dilmio_faq_answer_3.value
  endunless
  assign how_it_works_heading = landing_product.metafields.custom.dilmio_how_it_works_heading.value
  assign how_step_1_title     = landing_product.metafields.custom.dilmio_how_step_1_title.value
  assign how_step_1_text      = landing_product.metafields.custom.dilmio_how_step_1_text.value
  assign how_step_2_title     = landing_product.metafields.custom.dilmio_how_step_2_title.value
  assign how_step_2_text      = landing_product.metafields.custom.dilmio_how_step_2_text.value
  assign how_step_3_title     = landing_product.metafields.custom.dilmio_how_step_3_title.value
  assign how_step_3_text      = landing_product.metafields.custom.dilmio_how_step_3_text.value
-%}

<section
  id="dilmio-landing-{{ section.id }}"
  class="dilmio-landing"
  data-section-id="{{ section.id }}"
>

  {%- if landing_product == blank -%}

    {%- if request.design_mode -%}
      <div class="dilmio-placeholder">
        <p>Select a product in the Shopify customizer to activate this section.</p>
      </div>
    {%- endif -%}

  {%- else -%}

    {%- assign current_variant = landing_product.selected_or_first_available_variant -%}

    <script id="dilmio-variants-{{ section.id }}" type="application/json">
      [
        {%- for variant in landing_product.variants -%}
          {
            "id": {{ variant.id }},
            "title": {{ variant.title | json }},
            "price_formatted": {{ variant.price | money | json }},
            "available": {{ variant.available }},
            "option1": {{ variant.option1 | json }},
            "option2": {{ variant.option2 | json }},
            "option3": {{ variant.option3 | json }}
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ]
    </script>

    {%- comment -%} ── ABOVE THE FOLD ── {%- endcomment -%}
    {%- assign resolved_headline = hero_headline | default: landing_product.title -%}
    <div class="dilmio-stage-bg">
      <div id="dilmio-buy-core" class="dilmio-landing__inner">
        <div class="dilmio-hero"></div>
        <div class="dilmio-landing__media">
          {%- render 'dilmio-landing-gallery', product: landing_product -%}
        </div>
        {%- render 'dilmio-landing-form',
          product: landing_product,
          current_variant: current_variant,
          hero_subtitle: resolved_headline,
          hero_subheadline: hero_subheadline,
          benefit_1: benefit_1,
          benefit_2: benefit_2,
          benefit_3: benefit_3,
          benefit_4: benefit_4
        -%}
      </div>
    </div>

    {%- comment -%} ── EDITORIAL: POR QUÉ EXISTE ESTE PRODUCTO ── {%- endcomment -%}
    {%- assign ed_claim       = landing_product.metafields.custom.dilmio_editorial_claim.value -%}
    {%- assign ed_text        = landing_product.metafields.custom.dilmio_editorial_text.value -%}
    {%- assign ed_row_1_label = landing_product.metafields.custom.dilmio_editorial_row_1_label.value -%}
    {%- assign ed_row_1_value = landing_product.metafields.custom.dilmio_editorial_row_1_value.value -%}
    {%- assign ed_row_2_label = landing_product.metafields.custom.dilmio_editorial_row_2_label.value -%}
    {%- assign ed_row_2_value = landing_product.metafields.custom.dilmio_editorial_row_2_value.value -%}
    {%- assign ed_row_3_label = landing_product.metafields.custom.dilmio_editorial_row_3_label.value -%}
    {%- assign ed_row_3_value = landing_product.metafields.custom.dilmio_editorial_row_3_value.value -%}
    {%- assign ed_row_4_label = landing_product.metafields.custom.dilmio_editorial_row_4_label.value -%}
    {%- assign ed_row_4_value = landing_product.metafields.custom.dilmio_editorial_row_4_value.value -%}
    {%- assign prob_statement = landing_product.metafields.custom.dilmio_problem_statement.value -%}
    {%- assign sol_statement  = landing_product.metafields.custom.dilmio_solution_statement.value -%}
    {%- assign has_new_ed     = false -%}
    {%- if ed_claim != blank -%}{%- assign has_new_ed = true -%}{%- endif -%}
    {%- assign has_ed_table   = false -%}
    {%- if ed_row_1_label != blank or ed_row_2_label != blank or ed_row_3_label != blank or ed_row_4_label != blank -%}
      {%- assign has_ed_table = true -%}
    {%- endif -%}
    {%- assign ed_two_col = false -%}
    {%- if has_new_ed and has_ed_table -%}{%- assign ed_two_col = true -%}{%- endif -%}
    {%- if has_new_ed == false and prob_statement != blank and sol_statement != blank -%}{%- assign ed_two_col = true -%}{%- endif -%}

    {%- if has_new_ed or prob_statement != blank or sol_statement != blank -%}
      <div class="dilmio-editorial{% unless has_new_ed %} dilmio-editorial--legacy{% endunless %}">
        <div class="dilmio-editorial__inner{% if ed_two_col %} dilmio-editorial__inner--two-col{% else %} dilmio-editorial__inner--single{% endif %}">

          {%- if has_new_ed -%}
            <div class="dilmio-editorial__claim-col">
              <h2 class="dilmio-editorial__claim">{{ ed_claim }}</h2>
              {%- if ed_text != blank -%}
                <p class="dilmio-editorial__text">{{ ed_text }}</p>
              {%- endif -%}
            </div>
            {%- if has_ed_table -%}
              <div class="dilmio-editorial__table-col">
                <table class="dilmio-editorial__table">
                  {%- if ed_row_1_label != blank -%}
                    <tr class="dilmio-editorial__row">
                      <th class="dilmio-editorial__cell dilmio-editorial__cell--label">{{ ed_row_1_label }}</th>
                      <td class="dilmio-editorial__cell dilmio-editorial__cell--value">{{ ed_row_1_value }}</td>
                    </tr>
                  {%- endif -%}
                  {%- if ed_row_2_label != blank -%}
                    <tr class="dilmio-editorial__row">
                      <th class="dilmio-editorial__cell dilmio-editorial__cell--label">{{ ed_row_2_label }}</th>
                      <td class="dilmio-editorial__cell dilmio-editorial__cell--value">{{ ed_row_2_value }}</td>
                    </tr>
                  {%- endif -%}
                  {%- if ed_row_3_label != blank -%}
                    <tr class="dilmio-editorial__row">
                      <th class="dilmio-editorial__cell dilmio-editorial__cell--label">{{ ed_row_3_label }}</th>
                      <td class="dilmio-editorial__cell dilmio-editorial__cell--value">{{ ed_row_3_value }}</td>
                    </tr>
                  {%- endif -%}
                  {%- if ed_row_4_label != blank -%}
                    <tr class="dilmio-editorial__row">
                      <th class="dilmio-editorial__cell dilmio-editorial__cell--label">{{ ed_row_4_label }}</th>
                      <td class="dilmio-editorial__cell dilmio-editorial__cell--value">{{ ed_row_4_value }}</td>
                    </tr>
                  {%- endif -%}
                </table>
              </div>
            {%- endif -%}

          {%- elsif prob_statement != blank -%}
            <div class="dilmio-editorial__claim-col dilmio-editorial__claim-col--problem">
              <p class="dilmio-editorial__eyebrow">El problema</p>
              <p class="dilmio-editorial__claim dilmio-editorial__claim--legacy">{{ prob_statement }}</p>
            </div>
            {%- if sol_statement != blank -%}
              <div class="dilmio-editorial__table-col dilmio-editorial__table-col--solution">
                <p class="dilmio-editorial__eyebrow dilmio-editorial__eyebrow--light">La solución</p>
                <p class="dilmio-editorial__sol-text">{{ sol_statement }}</p>
              </div>
            {%- endif -%}
          {%- endif -%}

        </div>
      </div>
    {%- endif -%}

    {%- comment -%} ── VIDEO EDITORIAL ── {%- endcomment -%}
    {%- liquid
      assign video_heading = landing_product.metafields.custom.dilmio_demo_video_heading.value
      assign video_subtext = landing_product.metafields.custom.dilmio_demo_video_subtext.value
      assign show_video    = false
      if section.settings.show_demo_video and demo_video_url != blank
        assign show_video = true
      endif
    -%}
    {%- if show_video -%}
      <div class="dilmio-video-editorial">
        {%- if video_heading != blank or video_subtext != blank -%}
          <div class="dilmio-video-editorial__header">
            {%- if video_heading != blank -%}
              <h2 class="dilmio-video-editorial__heading">{{ video_heading }}</h2>
            {%- endif -%}
            {%- if video_subtext != blank -%}
              <p class="dilmio-video-editorial__sub">{{ video_subtext }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
        <div class="dilmio-video-editorial__frame">
          <video
            class="dilmio-video-editorial__player"
            src="{{ demo_video_url | escape }}"
            autoplay
            muted
            loop
            playsinline
          ></video>
        </div>
      </div>
    {%- endif -%}

    {%- comment -%} ── BEFORE / AFTER ── {%- endcomment -%}
    {%- render 'dilmio-landing-before-after', landing_product: landing_product -%}

    {%- comment -%} ── HOW IT WORKS ── {%- endcomment -%}
    {%- if section.settings.show_how_it_works -%}
      {%- render 'dilmio-landing-steps',
        heading: how_it_works_heading,
        step_1_title: how_step_1_title,
        step_1_text: how_step_1_text,
        step_2_title: how_step_2_title,
        step_2_text: how_step_2_text,
        step_3_title: how_step_3_title,
        step_3_text: how_step_3_text
      -%}
    {%- endif -%}

    {%- comment -%} ── BENEFITS ── {%- endcomment -%}
    {%- liquid
      assign has_benefits = false
      if section.settings.show_benefits
        if benefit_1 != blank or benefit_2 != blank or benefit_3 != blank or benefit_4 != blank
          assign has_benefits = true
        endif
      endif
    -%}
    {%- if has_benefits -%}
      <div class="dilmio-benefits-standalone">
        {%- render 'dilmio-landing-benefits',
          benefit_1: benefit_1,
          benefit_2: benefit_2,
          benefit_3: benefit_3,
          benefit_4: benefit_4
        -%}
      </div>
    {%- endif -%}

    {%- comment -%} ── FAQ STANDALONE ── {%- endcomment -%}
    {%- liquid
      assign has_faq = false
      if section.settings.show_faq
        if faq_question_1 != blank or faq_question_2 != blank or faq_question_3 != blank
          assign has_faq = true
        endif
      endif
    -%}
    {%- render 'dilmio-landing-faq',
      has_faq: has_faq,
      faq_question_1: faq_question_1,
      faq_answer_1: faq_answer_1,
      faq_question_2: faq_question_2,
      faq_answer_2: faq_answer_2,
      faq_question_3: faq_question_3,
      faq_answer_3: faq_answer_3,
      faq_support_text: '¿Dudas? Estamos para ayudarte.'
    -%}

    {%- liquid
      assign cta_heading = landing_product.metafields.custom.dilmio_cta_final_heading.value
      assign cta_sub     = landing_product.metafields.custom.dilmio_cta_final_subtext.value
      assign cta_btn     = 'Comprar ahora'
    -%}
    <div class="dilmio-cta-final">
      {%- if cta_heading != blank -%}
        <p class="dilmio-cta-final__heading">{{ cta_heading }}</p>
      {%- endif -%}
      {%- if cta_sub != blank -%}
        <p class="dilmio-cta-final__sub">{{ cta_sub }}</p>
      {%- endif -%}
      <a href="#dilmio-buy-core" class="dilmio-cta-final__btn">{{ cta_btn }}</a>
    </div>

    {%- render 'dilmio-landing-sticky', product: landing_product, current_variant: current_variant -%}

  {%- endif -%}

</section>

<script src="{{ 'dilmio-product.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "DILMIO Product Landing",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "header",
      "content": "Módulos"
    },
    {
      "type": "checkbox",
      "id": "show_pack",
      "label": "Show pack selector",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_benefits",
      "label": "Show benefits block",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_trust",
      "label": "Show trust bullets",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_faq",
      "label": "Show FAQ block",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_demo_video",
      "label": "Show demo video",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_how_it_works",
      "label": "Show how it works",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_before_after",
      "label": "Show before/after slider",
      "default": false
    },
    {
      "type": "text",
      "id": "before_after_kicker",
      "label": "Before/After — Kicker",
      "default": "Antes / Después"
    },
    {
      "type": "text",
      "id": "before_after_heading",
      "label": "Before/After — Heading",
      "default": "Antes y después"
    },
    {
      "type": "textarea",
      "id": "before_after_text",
      "label": "Before/After — Subtext"
    },
    {
      "type": "text",
      "id": "before_after_label_before",
      "label": "Before/After — Label antes",
      "default": "Antes"
    },
    {
      "type": "text",
      "id": "before_after_label_after",
      "label": "Before/After — Label después",
      "default": "Después"
    }
  ],
  "presets": [
    {
      "name": "DILMIO Product Landing"
    }
  ]
}
{% endschema %}
