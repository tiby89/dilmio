{{ 'dilmio-product.css' | asset_url | stylesheet_tag }}

{%- assign product = product | default: section.settings.product -%}
{%- if request.page_type == 'product' -%}
  {%- assign hero_headline        = product.metafields.custom.dilmio_hero_headline.value -%}
  {%- assign hero_subheadline     = product.metafields.custom.dilmio_hero_subheadline.value -%}
  {%- assign demo_video_url       = product.metafields.custom.dilmio_demo_video_url.value -%}
  {%- assign benefit_1            = product.metafields.custom.dilmio_benefit_1.value -%}
  {%- assign benefit_2            = product.metafields.custom.dilmio_benefit_2.value -%}
  {%- assign benefit_3            = product.metafields.custom.dilmio_benefit_3.value -%}
  {%- assign benefit_4            = product.metafields.custom.custom_dilmio_benefit_4.value -%}
  {%- assign faq_question_1       = product.metafields.custom.dilmio_faq_question_1.value -%}
  {%- assign faq_question_2       = product.metafields.custom.custom_dilmio_faq_question_2.value -%}
  {%- assign faq_answer_2         = product.metafields.custom.custom_dilmio_faq_answer_2.value -%}
  {%- assign faq_question_3       = product.metafields.custom.custom_dilmio_faq_question_3.value -%}
  {%- assign faq_answer_3         = product.metafields.custom.custom_dilmio_faq_answer_3.value -%}
  {%- assign how_it_works_heading = product.metafields.custom.dilmio_how_it_works_heading.value -%}
  {%- assign how_step_1_title     = product.metafields.custom.dilmio_how_step_1_title.value -%}
  {%- assign how_step_1_text      = product.metafields.custom.dilmio_how_step_1_text.value -%}
  {%- assign how_step_2_title     = product.metafields.custom.dilmio_how_step_2_title.value -%}
  {%- assign how_step_2_text      = product.metafields.custom.dilmio_how_step_2_text.value -%}
  {%- assign how_step_3_title     = product.metafields.custom.dilmio_how_step_3_title.value -%}
  {%- assign how_step_3_text      = product.metafields.custom.dilmio_how_step_3_text.value -%}
{%- else -%}
  {%- assign hero_headline        = section.settings.hero_headline -%}
  {%- assign hero_subheadline     = section.settings.hero_subheadline -%}
  {%- assign demo_video_url       = section.settings.demo_video_url -%}
  {%- assign benefit_1            = section.settings.benefit_1 -%}
  {%- assign benefit_2            = section.settings.benefit_2 -%}
  {%- assign benefit_3            = section.settings.benefit_3 -%}
  {%- assign benefit_4            = section.settings.benefit_4 -%}
  {%- assign faq_question_1       = section.settings.faq_question_1 -%}
  {%- assign faq_question_2       = section.settings.faq_question_2 -%}
  {%- assign faq_answer_2         = section.settings.faq_answer_2 -%}
  {%- assign faq_question_3       = section.settings.faq_question_3 -%}
  {%- assign faq_answer_3         = section.settings.faq_answer_3 -%}
  {%- assign how_it_works_heading = section.settings.how_it_works_heading -%}
  {%- assign how_step_1_title     = section.settings.how_it_works_step_1_title -%}
  {%- assign how_step_1_text      = section.settings.how_it_works_step_1_text -%}
  {%- assign how_step_2_title     = section.settings.how_it_works_step_2_title -%}
  {%- assign how_step_2_text      = section.settings.how_it_works_step_2_text -%}
  {%- assign how_step_3_title     = section.settings.how_it_works_step_3_title -%}
  {%- assign how_step_3_text      = section.settings.how_it_works_step_3_text -%}
{%- endif -%}

<section
  id="dilmio-landing-{{ section.id }}"
  class="dilmio-landing"
  data-section-id="{{ section.id }}"
>

  {%- if product == blank -%}

    <div class="dilmio-placeholder">
      <p>Select a product in the Shopify customizer to activate this section.</p>
    </div>

  {%- else -%}

    {%- assign current_variant = product.selected_or_first_available_variant -%}

    <script id="dilmio-variants-{{ section.id }}" type="application/json">
      [
        {%- for variant in product.variants -%}
          {
            "id": {{ variant.id }},
            "title": {{ variant.title | json }},
            "price_formatted": {{ variant.price | money | json }},
            "available": {{ variant.available }},
            "option1": {{ variant.option1 | json }},
            "option2": {{ variant.option2 | json }},
            "option3": {{ variant.option3 | json }}
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ]
    </script>

    {%- if hero_headline != blank or hero_subheadline != blank -%}
      <div class="dilmio-hero">
        {%- if hero_headline != blank -%}
          <div class="dilmio-hero__headline">{{ hero_headline | newline_to_br }}</div>
        {%- endif -%}
        {%- if hero_subheadline != blank -%}
          <p class="dilmio-hero__subheadline">{{ hero_subheadline }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="dilmio-landing__inner">

      <div class="dilmio-landing__media">
        {%- if product.featured_image -%}
          <img
            src="{{ product.featured_image | image_url: width: 800 }}"
            alt="{{ product.featured_image.alt | escape }}"
            width="800"
            height="{{ 800 | divided_by: product.featured_image.aspect_ratio | round }}"
            loading="eager"
          >
        {%- endif -%}
      </div>

      <div class="dilmio-landing__form">

        <h1 class="dilmio-landing__title">{{ product.title }}</h1>

        <div class="dilmio-landing__price" id="dilmio-price-{{ section.id }}">
          {{ current_variant.price | money }}
        </div>

        {%- unless product.has_only_default_variant -%}
          <div class="dilmio-options" id="dilmio-options-{{ section.id }}">
            {%- for option in product.options_with_values -%}
              {%- assign opt_index = forloop.index0 -%}
              <div class="dilmio-option-group" data-option-index="{{ opt_index }}">
                <p class="dilmio-option-group__label">{{ option.name }}</p>
                <div class="dilmio-option-group__values">
                  {%- for value in option.values -%}
                    <button
                      type="button"
                      class="dilmio-option-btn{% if option.selected_value == value %} is-selected{% endif %}"
                      data-option-index="{{ opt_index }}"
                      data-value="{{ value | escape }}"
                    >
                      {{ value }}
                    </button>
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}
          </div>
        {%- endunless -%}

        {%- if section.settings.show_pack -%}
          {%- assign has_packs = false -%}
          {%- if section.settings.pack_label_1 != blank and section.settings.pack_quantity_1 > 0 -%}{%- assign has_packs = true -%}{%- endif -%}
          {%- if section.settings.pack_label_2 != blank and section.settings.pack_quantity_2 > 0 -%}{%- assign has_packs = true -%}{%- endif -%}
          {%- if section.settings.pack_label_3 != blank and section.settings.pack_quantity_3 > 0 -%}{%- assign has_packs = true -%}{%- endif -%}
          {%- if has_packs -%}
          {%- assign first_pack_rendered = false -%}
          <div class="dilmio-packs" id="dilmio-packs-{{ section.id }}">
            <p class="dilmio-packs__label">Pack</p>
            <div class="dilmio-packs__values">

              {%- if section.settings.pack_label_1 != blank and section.settings.pack_quantity_1 > 0 -%}
                <button
                  type="button"
                  class="dilmio-pack-btn{%- unless first_pack_rendered %} is-selected{%- endunless -%}"
                  data-quantity="{{ section.settings.pack_quantity_1 }}"
                >{{ section.settings.pack_label_1 }}</button>
                {%- assign first_pack_rendered = true -%}
              {%- endif -%}

              {%- if section.settings.pack_label_2 != blank and section.settings.pack_quantity_2 > 0 -%}
                <button
                  type="button"
                  class="dilmio-pack-btn{%- unless first_pack_rendered %} is-selected{%- endunless -%}"
                  data-quantity="{{ section.settings.pack_quantity_2 }}"
                >{{ section.settings.pack_label_2 }}</button>
                {%- assign first_pack_rendered = true -%}
              {%- endif -%}

              {%- if section.settings.pack_label_3 != blank and section.settings.pack_quantity_3 > 0 -%}
                <button
                  type="button"
                  class="dilmio-pack-btn{%- unless first_pack_rendered %} is-selected{%- endunless -%}"
                  data-quantity="{{ section.settings.pack_quantity_3 }}"
                >{{ section.settings.pack_label_3 }}</button>
              {%- endif -%}

            </div>
          </div>
          {%- endif -%}
        {%- endif -%}

        <div class="dilmio-cta-wrap">
          <button
            type="button"
            id="dilmio-cta-{{ section.id }}"
            class="dilmio-cta"
            data-variant-id="{{ current_variant.id }}"
            {% unless current_variant.available %}disabled{% endunless %}
          >
            {%- if current_variant.available -%}Añadir al carrito{%- else -%}Agotado{%- endif -%}
          </button>
          <div
            id="dilmio-error-{{ section.id }}"
            class="dilmio-error"
            role="alert"
            style="display:none;"
          ></div>
        </div>

      </div>
    </div>

    {%- if section.settings.show_how_it_works -%}
      {%- assign has_steps = false -%}
      {%- if how_step_1_title != blank or how_step_1_text != blank -%}
        {%- assign has_steps = true -%}
      {%- endif -%}
      {%- if how_step_2_title != blank or how_step_2_text != blank -%}
        {%- assign has_steps = true -%}
      {%- endif -%}
      {%- if how_step_3_title != blank or how_step_3_text != blank -%}
        {%- assign has_steps = true -%}
      {%- endif -%}
      {%- if has_steps -%}
        <div class="dilmio-steps">
          {%- if how_it_works_heading != blank -%}
            <h2 class="dilmio-steps__heading">{{ how_it_works_heading }}</h2>
          {%- endif -%}
          <ol class="dilmio-steps__list">
            {%- if how_step_1_title != blank or how_step_1_text != blank -%}
              <li class="dilmio-steps__item">
                <div class="dilmio-steps__body">
                  {%- if how_step_1_title != blank -%}
                    <span class="dilmio-steps__title">{{ how_step_1_title }}</span>
                  {%- endif -%}
                  {%- if how_step_1_text != blank -%}
                    <span class="dilmio-steps__text">{{ how_step_1_text }}</span>
                  {%- endif -%}
                </div>
              </li>
            {%- endif -%}
            {%- if how_step_2_title != blank or how_step_2_text != blank -%}
              <li class="dilmio-steps__item">
                <div class="dilmio-steps__body">
                  {%- if how_step_2_title != blank -%}
                    <span class="dilmio-steps__title">{{ how_step_2_title }}</span>
                  {%- endif -%}
                  {%- if how_step_2_text != blank -%}
                    <span class="dilmio-steps__text">{{ how_step_2_text }}</span>
                  {%- endif -%}
                </div>
              </li>
            {%- endif -%}
            {%- if how_step_3_title != blank or how_step_3_text != blank -%}
              <li class="dilmio-steps__item">
                <div class="dilmio-steps__body">
                  {%- if how_step_3_title != blank -%}
                    <span class="dilmio-steps__title">{{ how_step_3_title }}</span>
                  {%- endif -%}
                  {%- if how_step_3_text != blank -%}
                    <span class="dilmio-steps__text">{{ how_step_3_text }}</span>
                  {%- endif -%}
                </div>
              </li>
            {%- endif -%}
          </ol>
        </div>
      {%- endif -%}
    {%- endif -%}

    {%- assign show_video = false -%}
    {%- if request.page_type == 'product' and demo_video_url != blank -%}
      {%- assign show_video = true -%}
    {%- elsif section.settings.show_demo_video and demo_video_url != blank -%}
      {%- assign show_video = true -%}
    {%- endif -%}

    {%- assign has_benefits = false -%}
    {%- if benefit_1 != blank or benefit_2 != blank or benefit_3 != blank or benefit_4 != blank -%}
      {%- assign has_benefits = true -%}
    {%- endif -%}

    {%- if show_video -%}
      <div class="dilmio-demo-section">
        {%- if section.settings.demo_video_heading != blank -%}
          <div class="dilmio-demo-header">
            <h2 class="dilmio-demo-header__title">{{ section.settings.demo_video_heading }}</h2>
          </div>
        {%- endif -%}
        <div class="dilmio-demo-split">
          <div class="dilmio-demo-split__video">
            <video
              class="dilmio-demo-split__player"
              src="{{ demo_video_url | escape }}"
              autoplay
              muted
              loop
              playsinline
            ></video>
          </div>
          {%- if has_benefits -%}
            <div class="dilmio-demo-split__content">
              {%- if section.settings.benefits_title != blank -%}
                <h3 class="dilmio-demo-split__benefits-title">{{ section.settings.benefits_title }}</h3>
              {%- endif -%}
              <ul class="dilmio-demo-split__benefits">
                {%- if benefit_1 != blank -%}
                  <li class="dilmio-demo-split__benefit">{{ benefit_1 }}</li>
                {%- endif -%}
                {%- if benefit_2 != blank -%}
                  <li class="dilmio-demo-split__benefit">{{ benefit_2 }}</li>
                {%- endif -%}
                {%- if benefit_3 != blank -%}
                  <li class="dilmio-demo-split__benefit">{{ benefit_3 }}</li>
                {%- endif -%}
                {%- if benefit_4 != blank -%}
                  <li class="dilmio-demo-split__benefit">{{ benefit_4 }}</li>
                {%- endif -%}
              </ul>
            </div>
          {%- endif -%}
        </div>
      </div>
    {%- elsif section.settings.show_benefits and has_benefits -%}
      <div class="dilmio-benefits">
        {%- if section.settings.benefits_title != blank -%}
          <h2 class="dilmio-benefits__title">{{ section.settings.benefits_title }}</h2>
        {%- endif -%}
        <ul class="dilmio-benefits__list">
          {%- if benefit_1 != blank -%}
            <li class="dilmio-benefits__item">{{ benefit_1 }}</li>
          {%- endif -%}
          {%- if benefit_2 != blank -%}
            <li class="dilmio-benefits__item">{{ benefit_2 }}</li>
          {%- endif -%}
          {%- if benefit_3 != blank -%}
            <li class="dilmio-benefits__item">{{ benefit_3 }}</li>
          {%- endif -%}
          {%- if benefit_4 != blank -%}
            <li class="dilmio-benefits__item">{{ benefit_4 }}</li>
          {%- endif -%}
        </ul>
      </div>
    {%- endif -%}

    {%- if section.settings.show_trust -%}
      {%- if section.settings.trust_1 != blank or section.settings.trust_2 != blank or section.settings.trust_3 != blank -%}
        <div class="dilmio-trust">
          <ul class="dilmio-trust__list">
            {%- if section.settings.trust_1 != blank -%}
              <li class="dilmio-trust__item">{{ section.settings.trust_1 }}</li>
            {%- endif -%}
            {%- if section.settings.trust_2 != blank -%}
              <li class="dilmio-trust__item">{{ section.settings.trust_2 }}</li>
            {%- endif -%}
            {%- if section.settings.trust_3 != blank -%}
              <li class="dilmio-trust__item">{{ section.settings.trust_3 }}</li>
            {%- endif -%}
          </ul>
        </div>
      {%- endif -%}
    {%- endif -%}

    {%- if section.settings.show_faq -%}
      {%- if faq_question_1 != blank or faq_question_2 != blank or faq_question_3 != blank -%}
        <div class="dilmio-faq">
          {%- if section.settings.faq_title != blank -%}
            <h2 class="dilmio-faq__title">{{ section.settings.faq_title }}</h2>
          {%- endif -%}
          {%- if faq_question_1 != blank -%}
            <details class="dilmio-faq__item">
              <summary class="dilmio-faq__question">{{ faq_question_1 }}</summary>
              {%- if request.page_type == 'product' -%}
                {%- if product.metafields.custom.dilmio_faq_answer_1.value != blank -%}
                  <div class="dilmio-faq__answer">{{ product.metafields.custom.dilmio_faq_answer_1.value | newline_to_br }}</div>
                {%- endif -%}
              {%- elsif section.settings.faq_answer_1 != blank -%}
                <div class="dilmio-faq__answer">{{ section.settings.faq_answer_1 }}</div>
              {%- endif -%}
            </details>
          {%- endif -%}
          {%- if faq_question_2 != blank -%}
            <details class="dilmio-faq__item">
              <summary class="dilmio-faq__question">{{ faq_question_2 }}</summary>
              {%- if faq_answer_2 != blank -%}
                <div class="dilmio-faq__answer">{{ faq_answer_2 | newline_to_br }}</div>
              {%- endif -%}
            </details>
          {%- endif -%}
          {%- if faq_question_3 != blank -%}
            <details class="dilmio-faq__item">
              <summary class="dilmio-faq__question">{{ faq_question_3 }}</summary>
              {%- if faq_answer_3 != blank -%}
                <div class="dilmio-faq__answer">{{ faq_answer_3 | newline_to_br }}</div>
              {%- endif -%}
            </details>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endif -%}

    <div
      id="dilmio-sticky-{{ section.id }}"
      class="dilmio-sticky"
      aria-hidden="true"
    >
      <div class="dilmio-sticky__inner">
        <div class="dilmio-sticky__info">
          <span class="dilmio-sticky__title">{{ product.title }}</span>
          {%- unless product.has_only_default_variant -%}
            <span
              class="dilmio-sticky__variant"
              id="dilmio-sticky-variant-{{ section.id }}"
            >{{ current_variant.title }}</span>
          {%- endunless -%}
          <span
            class="dilmio-sticky__price"
            id="dilmio-sticky-price-{{ section.id }}"
          >{{ current_variant.price | money }}</span>
        </div>
        <button
          type="button"
          id="dilmio-sticky-cta-{{ section.id }}"
          class="dilmio-cta dilmio-sticky__cta"
          data-variant-id="{{ current_variant.id }}"
          {% unless current_variant.available %}disabled{% endunless %}
        >
          {%- if current_variant.available -%}Añadir al carrito{%- else -%}Agotado{%- endif -%}
        </button>
      </div>
    </div>

  {%- endif -%}

</section>

<script src="{{ 'dilmio-product.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "DILMIO Product Landing",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "header",
      "content": "Pack selector"
    },
    {
      "type": "checkbox",
      "id": "show_pack",
      "label": "Show pack selector",
      "default": false
    },
    {
      "type": "text",
      "id": "pack_label_1",
      "label": "Pack 1 — label",
      "placeholder": "e.g. 1 unit"
    },
    {
      "type": "number",
      "id": "pack_quantity_1",
      "label": "Pack 1 — quantity",
      "default": 0
    },
    {
      "type": "text",
      "id": "pack_label_2",
      "label": "Pack 2 — label",
      "placeholder": "e.g. 2 units"
    },
    {
      "type": "number",
      "id": "pack_quantity_2",
      "label": "Pack 2 — quantity",
      "default": 0
    },
    {
      "type": "text",
      "id": "pack_label_3",
      "label": "Pack 3 — label",
      "placeholder": "e.g. 3 units"
    },
    {
      "type": "number",
      "id": "pack_quantity_3",
      "label": "Pack 3 — quantity",
      "default": 0
    },
    {
      "type": "header",
      "content": "Benefits"
    },
    {
      "type": "checkbox",
      "id": "show_benefits",
      "label": "Show benefits block",
      "default": false
    },
    {
      "type": "text",
      "id": "benefits_title",
      "label": "Benefits title",
      "placeholder": "e.g. Why customers love it"
    },
    {
      "type": "header",
      "content": "Trust"
    },
    {
      "type": "checkbox",
      "id": "show_trust",
      "label": "Show trust bullets",
      "default": false
    },
    {
      "type": "text",
      "id": "trust_1",
      "label": "Trust bullet 1",
      "placeholder": "e.g. Free shipping on orders over €30"
    },
    {
      "type": "text",
      "id": "trust_2",
      "label": "Trust bullet 2",
      "placeholder": "e.g. 30-day returns"
    },
    {
      "type": "text",
      "id": "trust_3",
      "label": "Trust bullet 3",
      "placeholder": "e.g. 100% satisfaction guarantee"
    },
    {
      "type": "header",
      "content": "FAQ"
    },
    {
      "type": "checkbox",
      "id": "show_faq",
      "label": "Show FAQ block",
      "default": false
    },
    {
      "type": "text",
      "id": "faq_title",
      "label": "FAQ title",
      "placeholder": "e.g. Frequently Asked Questions"
    },
    {
      "type": "header",
      "content": "Demo video"
    },
    {
      "type": "checkbox",
      "id": "show_demo_video",
      "label": "Show demo video",
      "default": false
    },
    {
      "type": "text",
      "id": "demo_video_heading",
      "label": "Video heading",
      "placeholder": "e.g. See it in action"
    },
    {
      "type": "header",
      "content": "How it works"
    },
    {
      "type": "checkbox",
      "id": "show_how_it_works",
      "label": "Show how it works",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "DILMIO Product Landing"
    }
  ]
}
{% endschema %}
