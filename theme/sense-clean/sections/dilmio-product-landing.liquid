{{ 'dilmio-product.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign landing_product = nil
  if section.settings.product != blank
    assign landing_product = section.settings.product
  elsif request.page_type == 'product'
    assign landing_product = product
  endif
-%}

{%- if request.page_type == 'product' -%}
  {%- assign hero_headline        = landing_product.metafields.custom.dilmio_hero_headline.value -%}
  {%- assign hero_subheadline     = landing_product.metafields.custom.dilmio_hero_subheadline.value -%}
  {%- assign demo_video_url       = landing_product.metafields.custom.dilmio_demo_video_url.value -%}
  {%- assign benefit_1            = landing_product.metafields.custom.dilmio_benefit_1.value -%}
  {%- assign benefit_2            = landing_product.metafields.custom.dilmio_benefit_2.value -%}
  {%- assign benefit_3            = landing_product.metafields.custom.dilmio_benefit_3.value -%}
  {%- assign benefit_4            = landing_product.metafields.custom.dilmio_benefit_4.value -%}
  {%- assign faq_question_1       = landing_product.metafields.custom.dilmio_faq_question_1.value -%}
  {%- assign faq_answer_1         = landing_product.metafields.custom.dilmio_faq_answer_1.value -%}
  {%- assign faq_question_2       = landing_product.metafields.custom.dilmio_faq_question_2.value -%}
  {%- if faq_question_2 == blank -%}{%- assign faq_question_2 = landing_product.metafields.custom.custom_dilmio_faq_question_2.value -%}{%- endif -%}
  {%- assign faq_answer_2         = landing_product.metafields.custom.dilmio_faq_answer_2.value -%}
  {%- if faq_answer_2 == blank -%}{%- assign faq_answer_2 = landing_product.metafields.custom.custom_dilmio_faq_answer_2.value -%}{%- endif -%}
  {%- assign faq_question_3       = landing_product.metafields.custom.dilmio_faq_question_3.value -%}
  {%- if faq_question_3 == blank -%}{%- assign faq_question_3 = landing_product.metafields.custom.custom_dilmio_faq_question_3.value -%}{%- endif -%}
  {%- assign faq_answer_3         = landing_product.metafields.custom.dilmio_faq_answer_3.value -%}
  {%- if faq_answer_3 == blank -%}{%- assign faq_answer_3 = landing_product.metafields.custom.custom_dilmio_faq_answer_3.value -%}{%- endif -%}
  {%- assign how_it_works_heading = landing_product.metafields.custom.dilmio_how_it_works_heading.value -%}
  {%- assign how_step_1_title     = landing_product.metafields.custom.dilmio_how_step_1_title.value -%}
  {%- assign how_step_1_text      = landing_product.metafields.custom.dilmio_how_step_1_text.value -%}
  {%- assign how_step_2_title     = landing_product.metafields.custom.dilmio_how_step_2_title.value -%}
  {%- assign how_step_2_text      = landing_product.metafields.custom.dilmio_how_step_2_text.value -%}
  {%- assign how_step_3_title     = landing_product.metafields.custom.dilmio_how_step_3_title.value -%}
  {%- assign how_step_3_text      = landing_product.metafields.custom.dilmio_how_step_3_text.value -%}
{%- else -%}
  {%- assign hero_headline        = section.settings.hero_headline -%}
  {%- assign hero_subheadline     = section.settings.hero_subheadline -%}
  {%- assign demo_video_url       = section.settings.demo_video_url -%}
  {%- assign benefit_1            = section.settings.benefit_1 -%}
  {%- assign benefit_2            = section.settings.benefit_2 -%}
  {%- assign benefit_3            = section.settings.benefit_3 -%}
  {%- assign benefit_4            = section.settings.benefit_4 -%}
  {%- assign faq_question_1       = section.settings.faq_question_1 -%}
  {%- assign faq_answer_1         = section.settings.faq_answer_1 -%}
  {%- assign faq_question_2       = section.settings.faq_question_2 -%}
  {%- assign faq_answer_2         = section.settings.faq_answer_2 -%}
  {%- assign faq_question_3       = section.settings.faq_question_3 -%}
  {%- assign faq_answer_3         = section.settings.faq_answer_3 -%}
  {%- assign how_it_works_heading = section.settings.how_it_works_heading -%}
  {%- assign how_step_1_title     = section.settings.how_it_works_step_1_title -%}
  {%- assign how_step_1_text      = section.settings.how_it_works_step_1_text -%}
  {%- assign how_step_2_title     = section.settings.how_it_works_step_2_title -%}
  {%- assign how_step_2_text      = section.settings.how_it_works_step_2_text -%}
  {%- assign how_step_3_title     = section.settings.how_it_works_step_3_title -%}
  {%- assign how_step_3_text      = section.settings.how_it_works_step_3_text -%}
{%- endif -%}

<section
  id="dilmio-landing-{{ section.id }}"
  class="dilmio-landing"
  data-section-id="{{ section.id }}"
>

  {%- if landing_product == blank -%}

    {%- if request.design_mode -%}
      <div class="dilmio-placeholder">
        <p>Select a product in the Shopify customizer to activate this section.</p>
      </div>
    {%- endif -%}

  {%- else -%}

    {%- assign current_variant = landing_product.selected_or_first_available_variant -%}

    <script id="dilmio-variants-{{ section.id }}" type="application/json">
      [
        {%- for variant in landing_product.variants -%}
          {
            "id": {{ variant.id }},
            "title": {{ variant.title | json }},
            "price_formatted": {{ variant.price | money | json }},
            "available": {{ variant.available }},
            "option1": {{ variant.option1 | json }},
            "option2": {{ variant.option2 | json }},
            "option3": {{ variant.option3 | json }}
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ]
    </script>

    {%- assign resolved_headline = hero_headline | default: landing_product.title -%}
    <div class="dilmio-hero">
      <div class="dilmio-hero__headline">{{ resolved_headline | newline_to_br }}</div>
      {%- if hero_subheadline != blank -%}
        <p class="dilmio-hero__subheadline">{{ hero_subheadline }}</p>
      {%- endif -%}
    </div>

    <div id="dilmio-buy-core" class="dilmio-landing__inner">
      <div class="dilmio-landing__media">
        {%- render 'dilmio-landing-gallery', product: landing_product -%}
      </div>
      {%- render 'dilmio-landing-form',
        product: landing_product,
        current_variant: current_variant,
        benefit_1: benefit_1,
        benefit_2: benefit_2,
        benefit_3: benefit_3,
        benefit_4: benefit_4
      -%}
    </div>

    {%- if section.settings.show_how_it_works -%}
      {%- render 'dilmio-landing-steps',
        heading: how_it_works_heading,
        step_1_title: how_step_1_title,
        step_1_text: how_step_1_text,
        step_2_title: how_step_2_title,
        step_2_text: how_step_2_text,
        step_3_title: how_step_3_title,
        step_3_text: how_step_3_text
      -%}
    {%- endif -%}

    {%- liquid
      assign show_video = false
      if section.settings.show_demo_video and demo_video_url != blank
        assign show_video = true
      endif

      assign has_benefits = false
      if section.settings.show_benefits
        if benefit_1 != blank or benefit_2 != blank or benefit_3 != blank or benefit_4 != blank
          assign has_benefits = true
        endif
      endif

      assign has_faq = false
      if section.settings.show_faq
        if faq_question_1 != blank or faq_question_2 != blank or faq_question_3 != blank
          assign has_faq = true
        endif
      endif
    -%}
    {%- render 'dilmio-landing-demo',
      show_video: show_video,
      demo_video_url: demo_video_url,
      has_benefits: has_benefits,
      benefit_1: benefit_1,
      benefit_2: benefit_2,
      benefit_3: benefit_3,
      benefit_4: benefit_4,
      has_faq: has_faq,
      faq_question_1: faq_question_1,
      faq_answer_1: faq_answer_1,
      faq_question_2: faq_question_2,
      faq_answer_2: faq_answer_2,
      faq_question_3: faq_question_3,
      faq_answer_3: faq_answer_3
    -%}

    {%- if section.settings.show_trust -%}
      {%- if section.settings.trust_1 != blank or section.settings.trust_2 != blank or section.settings.trust_3 != blank -%}
        <div class="dilmio-trust">
          <ul class="dilmio-trust__list">
            {%- if section.settings.trust_1 != blank -%}
              <li class="dilmio-trust__item">
                {%- if section.settings.trust_icon_1 != blank and section.settings.trust_icon_1 != 'none' -%}
                  <span class="dilmio-trust__icon">{% render 'dilmio-trust-icon', icon: section.settings.trust_icon_1 %}</span>
                {%- endif -%}
                {{ section.settings.trust_1 }}
              </li>
            {%- endif -%}
            {%- if section.settings.trust_2 != blank -%}
              <li class="dilmio-trust__item">
                {%- if section.settings.trust_icon_2 != blank and section.settings.trust_icon_2 != 'none' -%}
                  <span class="dilmio-trust__icon">{% render 'dilmio-trust-icon', icon: section.settings.trust_icon_2 %}</span>
                {%- endif -%}
                {{ section.settings.trust_2 }}
              </li>
            {%- endif -%}
            {%- if section.settings.trust_3 != blank -%}
              <li class="dilmio-trust__item">
                {%- if section.settings.trust_icon_3 != blank and section.settings.trust_icon_3 != 'none' -%}
                  <span class="dilmio-trust__icon">{% render 'dilmio-trust-icon', icon: section.settings.trust_icon_3 %}</span>
                {%- endif -%}
                {{ section.settings.trust_3 }}
              </li>
            {%- endif -%}
          </ul>
        </div>
      {%- endif -%}
    {%- endif -%}

    {%- render 'dilmio-landing-sticky', product: landing_product, current_variant: current_variant -%}

  {%- endif -%}

</section>

<script src="{{ 'dilmio-product.js' | asset_url }}" defer="defer"></script>

