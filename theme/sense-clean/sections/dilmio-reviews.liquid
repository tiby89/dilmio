{{ 'dilmio-reviews.css' | asset_url | stylesheet_tag }}

{%- liquid
  if request.page_type == 'product' and product != blank
    assign selected_product = product
  else
    assign selected_product = section.settings.product
  endif

  assign reviews_list = nil
  if selected_product != blank
    assign reviews_list = selected_product.metafields.custom.dilmio_reviews.value
  endif
-%}

{%- if reviews_list != blank or request.design_mode -%}
<section
  class="dilmio-reviews"
  id="dilmio-reviews-{{ section.id }}"
  aria-label="{{ section.settings.heading | default: 'Opiniones de clientes' | escape }}"
>
  {%- if section.settings.heading != blank -%}
  <div class="dilmio-reviews__header page-width">
    <h2 class="dilmio-reviews__title">{{ section.settings.heading | escape }}</h2>
  </div>
  {%- endif -%}

  {%- if reviews_list == blank -%}
    {%- if request.design_mode -%}
    <div class="dilmio-reviews__empty page-width">
      <p>Sin opiniones asignadas. Asigna el metafield <strong>custom.dilmio_reviews</strong> al producto desde Shopify Admin.</p>
    </div>
    {%- endif -%}
  {%- else -%}
  <div class="dilmio-reviews__scroll-wrapper">
    <div class="dilmio-reviews__track">
      {%- for review in reviews_list limit: 3 -%}
        {%- assign r_name   = review.reviewer_name.value -%}
        {%- assign r_rating = review.rating.value | plus: 0 -%}
        {%- assign r_text   = review.review_text.value -%}
        {%- assign r_image  = review.review_image.value -%}
        {%- assign r_date   = review.review_date.value -%}
        {%- assign r_video  = review.review_video_url.value -%}

        <article class="dilmio-reviews__card">

          {%- if r_image != blank -%}
          <div class="dilmio-reviews__card-image">
            <img
              src="{{ r_image | image_url: width: 600 }}"
              alt="{{ r_name | default: 'Opinión de cliente' | escape }}"
              loading="lazy"
              width="600"
              height="400"
            >
          </div>
          {%- endif -%}

          <div class="dilmio-reviews__card-body">

            {%- if r_rating > 0 -%}
            <div class="dilmio-reviews__stars" aria-label="{{ r_rating }} de 5 estrellas">
              {%- for i in (1..5) -%}
                <span
                  class="dilmio-reviews__star{% if i <= r_rating %} dilmio-reviews__star--filled{% endif %}"
                  aria-hidden="true"
                >&#9733;</span>
              {%- endfor -%}
            </div>
            {%- endif -%}

            <div class="dilmio-reviews__meta">
              {%- if r_name != blank -%}
              <span class="dilmio-reviews__name">{{ r_name | escape }}</span>
              {%- endif -%}
              {%- if r_date != blank -%}
              <time class="dilmio-reviews__date" datetime="{{ r_date }}">
                {{- r_date | date: '%d/%m/%Y' -}}
              </time>
              {%- endif -%}
            </div>

            {%- if r_text != blank -%}
            <p class="dilmio-reviews__text">{{ r_text | escape }}</p>
            {%- endif -%}

            {%- if r_video != blank -%}
            <a
              class="dilmio-reviews__video-link"
              href="{{ r_video | escape }}"
              target="_blank"
              rel="noopener noreferrer"
            >Ver vídeo de la opinión →</a>
            {%- endif -%}

          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
  {%- endif -%}

</section>
{%- endif -%}

{% schema %}
{
  "name": "DILMIO Reviews",
  "tag": "section",
  "class": "dilmio-reviews-section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Producto"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título de la sección",
      "default": "Opiniones de clientes"
    }
  ],
  "presets": [
    {
      "name": "DILMIO Reviews"
    }
  ]
}
{% endschema %}
