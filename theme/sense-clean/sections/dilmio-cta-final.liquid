{{ 'dilmio-narrative.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign landing_product = nil
  if section.settings.product != blank
    assign landing_product = section.settings.product
  elsif request.page_type == 'product'
    assign landing_product = product
  endif
-%}

{%- unless landing_product == blank -%}
  {%- if section.settings.show_cta_final -%}
    {%- assign cta_headline = landing_product.metafields.custom.dilmio_cta_final_headline.value -%}
    {%- if cta_headline == blank -%}
      {%- assign cta_headline = section.settings.cta_final_headline -%}
    {%- endif -%}
    <div class="dilmio-cta-final">
      {%- if cta_headline != blank -%}
        <p class="dilmio-cta-final__headline">{{ cta_headline }}</p>
      {%- endif -%}
      <a href="#dilmio-buy-core" class="dilmio-cta-final__button">{{ section.settings.cta_final_button_label }}</a>
    </div>
  {%- endif -%}
{%- endunless -%}

{% schema %}
{
  "name": "DILMIO CTA Final",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_cta_final",
      "label": "Show final CTA block",
      "default": true
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product (fallback for non-product pages)"
    },
    {
      "type": "text",
      "id": "cta_final_headline",
      "label": "Headline (schema fallback)",
      "placeholder": "e.g. ¿Listo para probarlo?"
    },
    {
      "type": "text",
      "id": "cta_final_button_label",
      "label": "Button label",
      "default": "Comprar ahora"
    }
  ],
  "presets": [
    {
      "name": "DILMIO — CTA Final"
    }
  ]
}
{% endschema %}
