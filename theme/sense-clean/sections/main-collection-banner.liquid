{% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
{{ 'component-collection-hero.css' | asset_url | stylesheet_tag }}

{%- assign has_image = false -%}
{%- assign hero_image = nil -%}
{%- if section.settings.editorial_image != blank -%}
  {%- assign has_image = true -%}
  {%- assign hero_image = section.settings.editorial_image -%}
{%- elsif section.settings.show_collection_image and collection.image -%}
  {%- assign has_image = true -%}
  {%- assign hero_image = collection.image -%}
{%- endif -%}

<div class="dilmio-collection-hero{% if has_image %} dilmio-collection-hero--has-image{% endif %} color-{{ section.settings.color_scheme }} gradient">

  <div class="dilmio-collection-hero__visual">
    {%- if has_image -%}
      {{- hero_image | image_url: width: 2000 | image_tag:
        class: 'dilmio-collection-hero__img',
        loading: 'eager',
        widths: '600, 900, 1200, 1600, 2000',
        sizes: '100vw'
      -}}
    {%- else -%}
      <div class="dilmio-collection-hero__fallback">
        <div class="dilmio-hero-visual__shape dilmio-hero-visual__shape--1"></div>
        <div class="dilmio-hero-visual__shape dilmio-hero-visual__shape--2"></div>
        <div class="dilmio-hero-visual__shape dilmio-hero-visual__shape--3"></div>
      </div>
    {%- endif -%}

    <div class="dilmio-collection-hero__content{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
      <h1 class="dilmio-collection-hero__heading">
        <span class="visually-hidden">{{ 'sections.collection_template.title' | t }}: </span>
        {{- collection.title | escape -}}
      </h1>
      {%- if section.settings.show_collection_description and collection.description != blank -%}
        <p class="dilmio-collection-hero__subtext">{{ collection.description | strip_html | truncate: 140 }}</p>
      {%- elsif section.settings.editorial_subtitle != blank -%}
        <p class="dilmio-collection-hero__subtext">{{ section.settings.editorial_subtitle | escape }}</p>
      {%- endif -%}
    </div>
  </div>

</div>

{% schema %}
{
  "name": "t:sections.main-collection-banner.name",
  "class": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.main-collection-banner.settings.paragraph.content"
    },
    {
      "type": "checkbox",
      "id": "show_collection_description",
      "default": true,
      "label": "t:sections.main-collection-banner.settings.show_collection_description.label"
    },
    {
      "type": "textarea",
      "id": "editorial_subtitle",
      "label": "Subtítulo editorial (fallback)",
      "default": "Productos útiles para el hogar, la cocina y el día a día. Seleccionados por diseño, practicidad y precio.",
      "info": "Se muestra si la colección no tiene descripción propia."
    },
    {
      "type": "checkbox",
      "id": "show_reassurance",
      "label": "Mostrar barra de confianza",
      "default": false
    },
    {
      "type": "text",
      "id": "reassurance_text",
      "label": "Texto de confianza (separado por ·)",
      "default": "Envío con seguimiento · Pago seguro · Selección revisada"
    },
    {
      "type": "image_picker",
      "id": "editorial_image",
      "label": "Imagen hero editorial",
      "info": "Tiene prioridad sobre la imagen de la colección. Si no hay imagen, se muestra un gradiente decorativo."
    },
    {
      "type": "checkbox",
      "id": "show_collection_image",
      "default": true,
      "label": "t:sections.main-collection-banner.settings.show_collection_image.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    }
  ]
}
{% endschema %}
