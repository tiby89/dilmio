{%- style -%}
  .dilmio-trust-bar {
    background-color: var(--dilmio-primary, #3E4A2D);
    width: 100%;
  }

  .dilmio-trust-bar__inner {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    padding: 0.75rem 2rem;
    max-width: 144rem;
    margin: 0 auto;
  }

  .dilmio-trust-bar__item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #F4EFE4;
    font-size: 1.2rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    line-height: 1.4;
    white-space: nowrap;
  }

  .dilmio-trust-bar__link,
  .dilmio-trust-bar__link:visited {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #F4EFE4;
    text-decoration: none;
  }

  .dilmio-trust-bar__link:hover {
    opacity: 0.8;
  }

  .dilmio-trust-bar__icon {
    font-size: 1.3rem;
    line-height: 1;
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .dilmio-trust-bar__icon svg {
    width: 1.6rem;
    height: 1.6rem;
    fill: currentColor;
    display: block;
  }

  @media screen and (max-width: 749px) {
    .dilmio-trust-bar__inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.6rem 1rem;
      padding: 0.8rem 1.6rem;
    }

    .dilmio-trust-bar__item {
      font-size: 1.1rem;
      white-space: normal;
    }

    .dilmio-trust-bar__item {
      display: none;
    }

    .dilmio-trust-bar__countdown {
      grid-column: 1 / -1;
      justify-content: center;
      border-right: none;
      padding-right: 0;
      margin-right: 0;
    }
  }

  .dilmio-trust-bar__countdown {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: #F4EFE4;
    font-size: 1.2rem;
    font-weight: 600;
    white-space: nowrap;
    border-right: none;
    padding-right: 0;
    margin-right: 1.5rem;
  }

  .dilmio-trust-bar__countdown-label {
    font-weight: 500;
  }

  .dilmio-trust-bar__countdown-timer {
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.05em;
  }

{%- endstyle -%}

<div class="dilmio-trust-bar">
  <div class="dilmio-trust-bar__inner">
    {%- assign show_timer = false -%}
    {%- if section.settings.show_countdown and section.settings.countdown_deadline != blank -%}
      {%- assign show_timer = true -%}
    {%- endif -%}

    {%- assign show_bar = false -%}
    {%- if section.settings.countdown_label != blank -%}
      {%- assign show_bar = true -%}
    {%- endif -%}
    {%- if show_timer -%}
      {%- assign show_bar = true -%}
    {%- endif -%}

    {%- if show_bar -%}
      <div class="dilmio-trust-bar__countdown" id="dilmio-countdown">
        {%- if section.settings.countdown_label != blank -%}
          <span class="dilmio-trust-bar__countdown-label">
            {{ section.settings.countdown_label | escape }}
          </span>
        {%- endif -%}
        {%- if show_timer -%}
          <span class="dilmio-trust-bar__countdown-timer"
                data-deadline="{{ section.settings.countdown_deadline }}">
            --:--:--
          </span>
        {%- endif -%}
      </div>
    {%- endif -%}
    {%- for block in section.blocks -%}
      {%- if block.settings.text != blank -%}
        <div class="dilmio-trust-bar__item" {{ block.shopify_attributes }}>
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="dilmio-trust-bar__link">
          {%- endif -%}
          {%- if block.settings.icon_svg != blank -%}
            <span class="dilmio-trust-bar__icon" aria-hidden="true">
              {%- case block.settings.icon_svg -%}
                {%- when 'icon-lock' -%}{{ 'icon-lock.svg' | inline_asset_content }}
                {%- when 'icon-truck' -%}{{ 'icon-truck.svg' | inline_asset_content }}
                {%- when 'icon-return' -%}{{ 'icon-return.svg' | inline_asset_content }}
                {%- when 'icon-chat-bubble' -%}{{ 'icon-chat-bubble.svg' | inline_asset_content }}
                {%- when 'icon-box' -%}{{ 'icon-box.svg' | inline_asset_content }}
                {%- when 'icon-padlock' -%}{{ 'icon-padlock.svg' | inline_asset_content }}
              {%- endcase -%}
            </span>
          {%- elsif block.settings.icon != blank -%}
            <span class="dilmio-trust-bar__icon" aria-hidden="true">{{ block.settings.icon }}</span>
          {%- endif -%}
          <span class="dilmio-trust-bar__text">{{ block.settings.text | escape }}</span>
          {%- if block.settings.link != blank -%}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{%- if section.settings.show_countdown and section.settings.countdown_deadline != blank -%}
<script>
(function() {
  var timerEl = document.querySelector(
    '.dilmio-trust-bar__countdown-timer'
  );
  if (!timerEl) return;
  var deadline = new Date(timerEl.dataset.deadline).getTime();
  function pad(n) { return String(n).padStart(2, '0'); }
  function tick() {
    var now = Date.now();
    var diff = deadline - now;
    if (diff <= 0) {
      timerEl.textContent = 'Oferta finalizada';
      timerEl.closest('.dilmio-trust-bar__countdown')
        .style.borderRight = 'none';
      return;
    }
    var days = Math.floor(diff / 86400000);
    var h = Math.floor((diff % 86400000) / 3600000);
    var m = Math.floor((diff % 3600000) / 60000);
    var s = Math.floor((diff % 60000) / 1000);
    timerEl.textContent = pad(days) + 'd · ' + pad(h) + 'h · ' + pad(m) + 'm · ' + pad(s) + 's';
    setTimeout(tick, 1000);
  }
  tick();
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "DILMIO Trust Bar",
  "class": "dilmio-trust-bar-section",
  "max_blocks": 4,
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "text",
      "id": "countdown_label",
      "label": "Mensaje de la barra",
      "placeholder": "Oferta especial hasta"
    },
    {
      "type": "text",
      "id": "countdown_deadline",
      "label": "Fecha límite (formato: YYYY-MM-DDTHH:MM)",
      "placeholder": "2026-06-01T23:59"
    },
    {
      "type": "checkbox",
      "id": "show_countdown",
      "label": "Mostrar countdown",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust item",
      "settings": [
        {
          "type": "select",
          "id": "icon_svg",
          "label": "SVG icon",
          "options": [
            { "value": "", "label": "Ninguno" },
            { "value": "icon-lock", "label": "Candado (pago seguro)" },
            { "value": "icon-truck", "label": "Camión (envío)" },
            { "value": "icon-return", "label": "Flecha circular (devoluciones)" },
            { "value": "icon-chat-bubble", "label": "Burbuja (atención)" },
            { "value": "icon-box", "label": "Caja (paquete)" },
            { "value": "icon-padlock", "label": "Candado alt" }
          ],
          "default": ""
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Emoji (fallback si no hay SVG)",
          "default": "✓"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Trust message"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DILMIO Trust Bar",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "icon_svg": "icon-truck",
            "icon": "🚚",
            "text": "Envío con seguimiento a toda España"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon_svg": "icon-return",
            "icon": "↩",
            "text": "Devoluciones fáciles 30 días"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon_svg": "icon-chat-bubble",
            "icon": "✉",
            "text": "Atención al cliente: hola@dilmio.com"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon_svg": "icon-lock",
            "icon": "🔒",
            "text": "Pago 100% seguro"
          }
        }
      ]
    }
  ]
}
{% endschema %}
