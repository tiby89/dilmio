{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}
{{ 'dilmio-footer.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .footer {
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .footer {
      margin-top: {{ section.settings.margin_top }}px;
    }

    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<footer class="footer color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="dilmio-footer__top page-width">
    <div class="dilmio-footer__grid">

      {%- comment -%} Columna 1 — Marca + RR.SS. {%- endcomment -%}
      <div class="dilmio-footer__col dilmio-footer__col--brand">
        {%- if settings.brand_image != blank -%}
          {%- assign brand_image_height = settings.brand_image_width | divided_by: settings.brand_image.aspect_ratio -%}
          <div class="dilmio-footer__logo" style="max-width: min(100%, {{ settings.brand_image_width }}px);">
            {{
              settings.brand_image
              | image_url: width: 400
              | image_tag:
                loading: 'lazy',
                widths: '50, 100, 150, 200, 300, 400',
                height: brand_image_height,
                width: settings.brand_image_width,
                alt: shop.name
            }}
          </div>
        {%- else -%}
          <p class="dilmio-footer__shop-name">{{ shop.name }}</p>
        {%- endif -%}

        {%- if settings.brand_description != blank -%}
          <div class="dilmio-footer__tagline rte">{{ settings.brand_description }}</div>
        {%- endif -%}

        {%- liquid
          assign has_social_icons = false
          if settings.social_facebook_link != blank or settings.social_instagram_link != blank or settings.social_youtube_link != blank or settings.social_tiktok_link != blank or settings.social_twitter_link != blank or settings.social_pinterest_link != blank or settings.social_snapchat_link != blank or settings.social_tumblr_link != blank or settings.social_vimeo_link != blank
            assign has_social_icons = true
          endif
        -%}
        {%- if has_social_icons -%}
          {%- render 'social-icons', class: 'footer__list-social' -%}
        {%- endif -%}
      </div>

      {%- comment -%} Columna 2 — Tres bloques de links {%- endcomment -%}
      <div class="dilmio-footer__col dilmio-footer__col--links">
        {%- if section.settings.footer_col2_menu_1 != blank -%}
          <div class="dilmio-footer__link-group">
            {%- if section.settings.footer_col2_title_1 != blank -%}
              <h3 class="dilmio-footer__link-heading">{{ section.settings.footer_col2_title_1 | escape }}</h3>
            {%- endif -%}
            <ul class="dilmio-footer__link-list list-unstyled">
              {%- for link in section.settings.footer_col2_menu_1.links -%}
                <li>
                  <a
                    href="{{ link.url }}"
                    class="dilmio-footer__link{% if link.active %} dilmio-footer__link--active{% endif %}"
                  >
                    {{ link.title | escape }}
                  </a>
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}

        {%- if section.settings.footer_col2_menu_2 != blank -%}
          <div class="dilmio-footer__link-group">
            {%- if section.settings.footer_col2_title_2 != blank -%}
              <h3 class="dilmio-footer__link-heading">{{ section.settings.footer_col2_title_2 | escape }}</h3>
            {%- endif -%}
            <ul class="dilmio-footer__link-list list-unstyled">
              {%- for link in section.settings.footer_col2_menu_2.links -%}
                <li>
                  <a
                    href="{{ link.url }}"
                    class="dilmio-footer__link{% if link.active %} dilmio-footer__link--active{% endif %}"
                  >
                    {{ link.title | escape }}
                  </a>
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}

        {%- if section.settings.footer_col2_menu_3 != blank -%}
          <div class="dilmio-footer__link-group">
            {%- if section.settings.footer_col2_title_3 != blank -%}
              <h3 class="dilmio-footer__link-heading">{{ section.settings.footer_col2_title_3 | escape }}</h3>
            {%- endif -%}
            <ul class="dilmio-footer__link-list list-unstyled">
              {%- for link in section.settings.footer_col2_menu_3.links -%}
                <li>
                  <a
                    href="{{ link.url }}"
                    class="dilmio-footer__link{% if link.active %} dilmio-footer__link--active{% endif %}"
                  >
                    {{ link.title | escape }}
                  </a>
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Columna 3 — Suscripción email {%- endcomment -%}
      <div class="dilmio-footer__col dilmio-footer__col--newsletter">
        {%- if section.settings.footer_newsletter_heading != blank -%}
          <h3 class="dilmio-footer__link-heading">{{ section.settings.footer_newsletter_heading | escape }}</h3>
        {%- endif -%}
        {%- if section.settings.footer_newsletter_subtext != blank -%}
          <p class="dilmio-footer__newsletter-subtext">{{ section.settings.footer_newsletter_subtext | escape }}</p>
        {%- endif -%}
        {%- form 'customer', id: 'ContactFooter', class: 'footer__newsletter newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="newsletter-form__field-wrapper">
            <div class="field">
              <input
                id="NewsletterForm--{{ section.id }}"
                type="email"
                name="contact[email]"
                class="field__input"
                value="{{ form.email }}"
                aria-required="true"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                {% if form.errors %}
                  autofocus
                  aria-invalid="true"
                  aria-describedby="ContactFooter-error"
                {% elsif form.posted_successfully? %}
                  aria-describedby="ContactFooter-success"
                {% endif %}
                placeholder="{{ 'newsletter.label' | t }}"
                required
              >
              <label class="field__label" for="NewsletterForm--{{ section.id }}">
                {{ 'newsletter.label' | t }}
              </label>
              <button
                type="submit"
                class="newsletter-form__button field__button"
                name="commit"
                id="Subscribe"
                aria-label="{{ 'newsletter.button_label' | t }}"
              >
                <span class="svg-wrapper">
                  {{- 'icon-arrow.svg' | inline_asset_content -}}
                </span>
              </button>
            </div>
            {%- if form.errors -%}
              <small class="newsletter-form__message form__message" id="ContactFooter-error">
                <span class="svg-wrapper">
                  {{- 'icon-error.svg' | inline_asset_content -}}
                </span>
                {{- form.errors.translated_fields.email | capitalize }}
                {{ form.errors.messages.email -}}
              </small>
            {%- endif -%}
          </div>
          {%- if form.posted_successfully? -%}
            <h3
              class="newsletter-form__message newsletter-form__message--success form__message"
              id="ContactFooter-success"
              tabindex="-1"
              autofocus
            >
              <span class="svg-wrapper">
                {{- 'icon-success.svg' | inline_asset_content -}}
              </span>
              {{- 'newsletter.success' | t }}
            </h3>
          {%- endif -%}
        {%- endform -%}
        <p class="dilmio-footer__privacy-note">Sin spam. Puedes darte de baja cuando quieras.</p>
      </div>

    </div>
  </div>

  <div
    class="footer__content-bottom{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
    {% if settings.animations_reveal_on_scroll %}
      data-cascade
    {% endif %}
  >
    <div class="footer__content-bottom-wrapper page-width">
      <div class="footer__column footer__localization isolate"></div>
      <div class="footer__column footer__column--info">
        {%- if section.settings.payment_enable -%}
          <div class="footer__payment">
            <span class="visually-hidden">{{ 'sections.footer.payment' | t }}</span>
            <ul class="list list-payment" role="list">
              {%- for type in shop.enabled_payment_types -%}
                <li class="list-payment__item">
                  {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      </div>
    </div>
    <div class="footer__content-bottom-wrapper page-width footer__content-bottom-wrapper--center">
      <div class="footer__copyright caption">
        <small class="copyright__content"
          >&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. Todos los derechos reservados.
        </small>
        {%- comment -%}<small class="copyright__content">{{ powered_by_link }}</small>{%- endcomment -%}
        {%- if section.settings.show_policy -%}
          <ul class="policies list-unstyled">
            {%- for policy in shop.policies -%}
              {%- if policy != blank -%}
                <li>
                  <small class="copyright__content"
                    ><a href="{{ policy.url }}">{{ policy.title | escape }}</a></small
                  >
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "t:sections.footer.name",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Columna 1 — Marca"
    },
    {
      "type": "paragraph",
      "content": "El logo y la descripción se configuran en Configuración del tema > Logo."
    },
    {
      "type": "header",
      "content": "Columna 2 — Links"
    },
    {
      "type": "text",
      "id": "footer_col2_title_1",
      "label": "Título bloque 1",
      "default": "Tienda"
    },
    {
      "type": "link_list",
      "id": "footer_col2_menu_1",
      "label": "Menú bloque 1"
    },
    {
      "type": "text",
      "id": "footer_col2_title_2",
      "label": "Título bloque 2",
      "default": "Ayuda"
    },
    {
      "type": "link_list",
      "id": "footer_col2_menu_2",
      "label": "Menú bloque 2"
    },
    {
      "type": "text",
      "id": "footer_col2_title_3",
      "label": "Título bloque 3",
      "default": "Legal"
    },
    {
      "type": "link_list",
      "id": "footer_col2_menu_3",
      "label": "Menú bloque 3"
    },
    {
      "type": "header",
      "content": "Columna 3 — Suscripción"
    },
    {
      "type": "text",
      "id": "footer_newsletter_heading",
      "label": "Título del formulario",
      "default": "Recibe novedades"
    },
    {
      "type": "text",
      "id": "footer_newsletter_subtext",
      "label": "Texto bajo el título"
    },
    {
      "type": "header",
      "content": "Fila inferior"
    },
    {
      "type": "checkbox",
      "id": "payment_enable",
      "default": true,
      "label": "t:sections.footer.settings.payment_enable.label"
    },
    {
      "type": "checkbox",
      "id": "show_policy",
      "default": true,
      "label": "t:sections.footer.settings.show_policy.label",
      "info": "t:sections.footer.settings.show_policy.info"
    },
    {
      "type": "header",
      "content": "t:sections.all.spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.footer.settings.margin_top.label",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
