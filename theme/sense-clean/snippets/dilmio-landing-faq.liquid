{%- comment -%}
  Params: has_faq, faq_question_1/2/3, faq_answer_1/2/3, faq_support_text
{%- endcomment -%}
{%- if has_faq -%}
  <div class="dilmio-faq-standalone">
    <div class="dilmio-faq-standalone__inner">

      <div class="dilmio-faq-standalone__lead">
        <h2 class="dilmio-faq-standalone__title">Preguntas frecuentes</h2>
        {%- if faq_support_text != blank -%}
          <p class="dilmio-faq-standalone__support">{{ faq_support_text }}</p>
        {%- else -%}
          <p class="dilmio-faq-standalone__support">¿Dudas? Estamos para ayudarte.</p>
        {%- endif -%}
      </div>

      <div class="dilmio-faq-standalone__items">
        {%- if faq_question_1 != blank -%}
          <details class="dilmio-faq__item">
            <summary class="dilmio-faq__question">{{ faq_question_1 }}</summary>
            {%- if faq_answer_1 != blank -%}
              <div class="dilmio-faq__answer">{{ faq_answer_1 | newline_to_br }}</div>
            {%- endif -%}
          </details>
        {%- endif -%}
        {%- if faq_question_2 != blank -%}
          <details class="dilmio-faq__item">
            <summary class="dilmio-faq__question">{{ faq_question_2 }}</summary>
            {%- if faq_answer_2 != blank -%}
              <div class="dilmio-faq__answer">{{ faq_answer_2 | newline_to_br }}</div>
            {%- endif -%}
          </details>
        {%- endif -%}
        {%- if faq_question_3 != blank -%}
          <details class="dilmio-faq__item">
            <summary class="dilmio-faq__question">{{ faq_question_3 }}</summary>
            {%- if faq_answer_3 != blank -%}
              <div class="dilmio-faq__answer">{{ faq_answer_3 | newline_to_br }}</div>
            {%- endif -%}
          </details>
        {%- endif -%}
      </div>

    </div>
  </div>
{%- endif -%}
