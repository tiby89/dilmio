{%- comment -%}
  Params: product, current_variant, benefit_1, benefit_2, benefit_3, benefit_4
{%- endcomment -%}
<div class="dilmio-landing__form">

  <h1 class="dilmio-landing__title">{{ product.title }}</h1>

  {%- if hero_subtitle != blank -%}
    <p class="dilmio-form__subtitle">{{ hero_subtitle | newline_to_br }}</p>
  {%- endif -%}

  {%- if hero_subheadline != blank -%}
    <p class="dilmio-form__subcopy">{{ hero_subheadline }}</p>
  {%- endif -%}

  {%- assign rating_avg   = product.metafields.custom.dilmio_rating_avg.value -%}
  {%- assign rating_count = product.metafields.custom.dilmio_rating_count.value -%}
  <div class="dilmio-price-rating-row">
    <div class="dilmio-landing__price" id="dilmio-price-{{ section.id }}">
      {{ current_variant.price | money }}
    </div>
    {%- if rating_avg != blank and rating_count != blank -%}
      {%- assign star_pct = rating_avg | divided_by: 5.0 | times: 100 | round -%}
      <div class="dilmio-rating">
        <span class="dilmio-rating__stars" aria-label="{{ rating_avg }} de 5 estrellas">
          <span class="dilmio-rating__stars-bg">★★★★★</span>
          <span class="dilmio-rating__stars-fg" style="width:{{ star_pct }}%">★★★★★</span>
        </span>
        <span class="dilmio-rating__avg">{{ rating_avg }}</span>
        <span class="dilmio-rating__count">({{ rating_count }})</span>
      </div>
    {%- endif -%}
  </div>

  {%- unless product.has_only_default_variant -%}
    <div class="dilmio-options" id="dilmio-options-{{ section.id }}">
      {%- for option in product.options_with_values -%}
        {%- assign opt_index = forloop.index0 -%}
        <div class="dilmio-option-group" data-option-index="{{ opt_index }}">
          <p class="dilmio-option-group__label">{{ option.name }}</p>
          <div class="dilmio-option-group__values">
            {%- for value in option.values -%}
              {%- assign swatch_variant = nil -%}
              {%- assign swatch_found = false -%}
              {%- for v in product.variants -%}
                {%- unless swatch_found -%}
                  {%- if opt_index == 0 and v.option1 == value and v.featured_image -%}
                    {%- assign swatch_variant = v -%}
                    {%- assign swatch_found = true -%}
                  {%- elsif opt_index == 1 and v.option2 == value and v.featured_image -%}
                    {%- assign swatch_variant = v -%}
                    {%- assign swatch_found = true -%}
                  {%- elsif opt_index == 2 and v.option3 == value and v.featured_image -%}
                    {%- assign swatch_variant = v -%}
                    {%- assign swatch_found = true -%}
                  {%- endif -%}
                {%- endunless -%}
              {%- endfor -%}
              <button
                type="button"
                class="dilmio-option-btn{%- if swatch_variant %} dilmio-option-btn--swatch{%- endif -%}{% if option.selected_value == value %} is-selected{% endif %}"
                data-option-index="{{ opt_index }}"
                data-value="{{ value | escape }}"
              >
                {%- if swatch_variant -%}
                  <span class="dilmio-option-btn__img"><img src="{{ swatch_variant.featured_image | image_url: width: 120 }}" alt="{{ value | escape }}" width="60" loading="lazy"></span>
                  <span class="dilmio-option-btn__lbl">{{ value }}</span>
                {%- else -%}
                  {{ value }}
                {%- endif -%}
              </button>
            {%- endfor -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  {%- endunless -%}

  {%- if section.settings.show_pack -%}
    <div class="dilmio-packs" id="dilmio-packs-{{ section.id }}">
      <p class="dilmio-packs__label">Pack</p>
      <div class="dilmio-packs__values">
        <button type="button" class="dilmio-pack-btn is-selected" data-quantity="1">1 unidad</button>
        <button type="button" class="dilmio-pack-btn" data-quantity="2">2 unidades</button>
        <button type="button" class="dilmio-pack-btn" data-quantity="3">3 unidades</button>
      </div>
    </div>
  {%- endif -%}

  {%- if current_variant.available -%}
    <div class="dilmio-stock-badge">
      <span class="dilmio-stock-badge__dot"></span>
      En stock
    </div>
  {%- endif -%}

  <div class="dilmio-cta-wrap">
    <button
      type="button"
      id="dilmio-cta-{{ section.id }}"
      class="dilmio-cta"
      data-variant-id="{{ current_variant.id }}"
      data-add-label="Comprar"
      data-sold-out-label="Sin stock"
      data-unavailable-label="No disponible"
      {% unless current_variant.available %}disabled{% endunless %}
    >
      {%- if current_variant.available -%}Comprar{%- else -%}Sin stock{%- endif -%}
    </button>
    <div
      id="dilmio-error-{{ section.id }}"
      class="dilmio-error"
      role="alert"
      style="display:none;"
      data-error-add="{{ 'sections.cart_items.cart_error' | t | escape }}"
      data-error-generic="{{ 'general.error.server_error' | t | default: 'Something went wrong. Please try again.' | escape }}"
    ></div>
  </div>

  {%- if section.settings.show_trust -%}
    <div class="dilmio-trust-inline">
      <span class="dilmio-trust-inline__item">
        <span class="dilmio-trust__icon">{% render 'dilmio-trust-icon', icon: 'truck' %}</span>
        Envío con seguimiento
      </span>
      <span class="dilmio-trust-inline__item">
        <span class="dilmio-trust__icon">{% render 'dilmio-trust-icon', icon: 'shield' %}</span>
        Pago seguro
      </span>
      <span class="dilmio-trust-inline__item">
        <span class="dilmio-trust__icon">{% render 'dilmio-trust-icon', icon: 'return' %}</span>
        Devolución sencilla
      </span>
    </div>
  {%- endif -%}

</div>
